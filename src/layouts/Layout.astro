---
import NeonOverride from '../components/NeonOverride.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'kitsunebi',
  description = 'A board for the Skulk. Each card a flame, the whole a procession of lanterns.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://kitsunebi.kitsuneden.net');
const ogImage = new URL('/og-image.png', Astro.site ?? 'https://kitsunebi.kitsuneden.net');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="kitsunebi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:url" content={canonical.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <NeonOverride />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Foxfire palette */
    --bg-0: #0a0a0c;
    --bg-1: #12121518;
    --bg-card: #17171c;
    --bg-card-hover: #1c1c22;
    --border: #27272e;
    --border-soft: #1e1e24;
    --text: #e8e6e1;
    --text-dim: #9b9aa0;
    --text-soft: #6b6a70;

    /* Status flame colors */
    --flame-backlog: #4aa8d8;      /* cool cyan ~ dormant */
    --flame-in_progress: #ff8a3d;  /* warm orange ~ burning */
    --flame-blocked: #e8475a;      /* alert red */
    --flame-done: #d9b268;         /* amber ~ settled */
    --flame-archived: #4a4a52;     /* muted gray */

    --flame-backlog-glow: #4aa8d822;
    --flame-in_progress-glow: #ff8a3d2a;
    --flame-blocked-glow: #e8475a22;
    --flame-done-glow: #d9b26820;
    --flame-archived-glow: #4a4a5218;

    --font-sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Inter, sans-serif;
    --font-mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    --font-serif: "Cormorant Garamond", "EB Garamond", Georgia, "Times New Roman", serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    background: var(--bg-0);
    position: relative;
  }

  /* Fixed background: Miso-style kitsunebi torii-and-foxfire scene.
     Pseudo-element so we can stack a dark overlay cleanly and avoid
     iOS's janky background-attachment: fixed behavior. */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      url('/bg/kitsunebi-torii.webp') center center / cover no-repeat;
    z-index: -2;
    /* Subtle desaturation to let the foxfire palette win */
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    /* Very light vignette only ~ the image is already dark, cards
       have their own dark fill, so we just need corners framed and
       a hint of mood, not a wall of darkness. */
    background: radial-gradient(
      ellipse at center,
      rgba(10, 10, 14, 0.05) 0%,
      rgba(10, 10, 14, 0.35) 70%,
      rgba(10, 10, 14, 0.55) 100%
    );
    z-index: -1;
    pointer-events: none;
  }

  a {
    color: var(--flame-in_progress);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-card);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    border: 1px solid var(--border-soft);
  }

  kbd {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-card);
    color: var(--text-dim);
    padding: 0.05em 0.4em;
    border-radius: 3px;
    border: 1px solid var(--border);
    box-shadow: 0 1px 0 var(--border-soft);
    vertical-align: baseline;
  }

  pre {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    padding: 0.75em;
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.85em;
  }

  pre code {
    background: transparent;
    border: none;
    padding: 0;
  }

  ::selection {
    background: var(--flame-in_progress);
    color: var(--bg-0);
  }
</style>
