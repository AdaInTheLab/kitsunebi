---
import { getCollection } from 'astro:content';
import { readdirSync } from 'node:fs';
import Layout from '../layouts/Layout.astro';
import Column from '../components/Column.astro';
import Flame from '../components/Flame.astro';

const allCards = await getCollection('cards');

// Sanity check: Astro silently drops cards/*.md files that fail schema
// validation, with no build warning. (Cost us a day where kc-troubleshooting-docs
// vanished from the live board because of `completed: null`.) Compare the
// loaded collection against the on-disk file list and fail the build with a
// useful message if any are missing.
const onDisk = readdirSync('./cards').filter((f) => f.endsWith('.md')).map((f) => f.replace(/\.md$/, ''));
const loadedIds = new Set(allCards.map((c) => c.id));
const missing = onDisk.filter((id) => !loadedIds.has(id));
if (missing.length > 0) {
  throw new Error(
    `kitsunebi build: ${missing.length} card(s) failed schema validation and were silently dropped:\n` +
    missing.map((m) => `  - cards/${m}.md`).join('\n') +
    `\n\nCheck frontmatter against src/content.config.ts. Common gotchas:\n` +
    `  - status must be one of: backlog | in_progress | blocked | done | archived (note underscore)\n` +
    `  - dates must be YYYY-MM-DD or omitted; use 'completed: null' only on fields that allow null`
  );
}

// Sort: newer `created` dates first within a column; overdue/urgent float up within in-progress
const sorted = allCards.slice().sort((a, b) => {
  const ca = a.data.created || '';
  const cb = b.data.created || '';
  return cb.localeCompare(ca);
});

const columns = [
  { status: 'backlog' as const, label: 'Backlog' },
  { status: 'blocked' as const, label: 'Blocked' },
  { status: 'in_progress' as const, label: 'In Progress' },
  { status: 'done' as const, label: 'Done' },
];

const cardsByStatus = Object.fromEntries(
  columns.map((c) => [c.status, sorted.filter((card) => card.data.status === c.status)])
);

const totalActive = cardsByStatus.in_progress.length + cardsByStatus.blocked.length + cardsByStatus.backlog.length;

// Owner breakdown — only count active cards (not done/archived)
const activeCards = sorted.filter((c) => c.data.status !== 'done' && c.data.status !== 'archived');
const ownerCounts = new Map<string, number>();
for (const c of activeCards) {
  ownerCounts.set(c.data.owner, (ownerCounts.get(c.data.owner) ?? 0) + 1);
}
const ownerList = [...ownerCounts.entries()].sort((a, b) => b[1] - a[1]);

// All unique tags, for the filter bar
const tagSet = new Set<string>();
for (const c of sorted) for (const t of c.data.tags) tagSet.add(t);
const allTags = [...tagSet].sort();

// All unique people (owners + collaborators)
const peopleSet = new Set<string>();
for (const c of sorted) {
  peopleSet.add(c.data.owner);
  for (const p of c.data.collaborators) peopleSet.add(p);
}
const allPeople = [...peopleSet].sort();
---

<Layout title="kitsunebi — the Skulk's board">
  <main>
    <header class="site-head">
      <div class="brand">
        <Flame size={28} class="brand-flame" />
        <h1>kitsunebi</h1>
      </div>
      <p class="tagline">
        A board for the Skulk. Each card a flame, the whole a procession of lanterns.
      </p>
      <div class="stats">
        <span>{allCards.length} cards total</span>
        <span class="dot">·</span>
        <span>{totalActive} active</span>
        <span class="dot">·</span>
        <span>{cardsByStatus.done.length} shipped</span>
      </div>
      {ownerList.length > 0 && (
        <div class="owners" aria-label="Active cards by owner">
          {ownerList.map(([owner, count]) => (
            <a href={`/people/${owner}/`} class="owner-pill">
              <span class="owner-name">{owner}</span>
              <span class="owner-count">{count}</span>
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="filter-bar" role="search" aria-label="Filter cards">
      <input
        type="search"
        id="filter-search"
        placeholder="filter by text (press /)"
        aria-label="Filter cards by text"
      />
      <div class="filter-pills">
        <button type="button" class="filter-pill is-active" data-filter="person" data-value="">all people</button>
        {allPeople.map((p) => (
          <button type="button" class="filter-pill" data-filter="person" data-value={p}>🦊 {p}</button>
        ))}
      </div>
      {allTags.length > 0 && (
        <div class="filter-pills tag-pills">
          <button type="button" class="filter-pill is-active" data-filter="tag" data-value="">all tags</button>
          {allTags.map((t) => (
            <button type="button" class="filter-pill tag-filter" data-filter="tag" data-value={t}>#{t}</button>
          ))}
        </div>
      )}
      <button type="button" class="filter-clear" data-clear>clear</button>
    </div>

    <div class="board">
      {columns.map((c) => (
        <Column status={c.status} label={c.label} cards={cardsByStatus[c.status]} />
      ))}
    </div>

    <script>
      type FilterState = { person: string; tag: string; text: string };
      const state: FilterState = { person: '', tag: '', text: '' };

      const searchInput = document.getElementById('filter-search') as HTMLInputElement | null;
      const clearBtn = document.querySelector<HTMLButtonElement>('[data-clear]');

      function applyFilters() {
        const text = state.text.trim().toLowerCase();
        document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
          const cardText = card.textContent?.toLowerCase() ?? '';
          const owner = card.dataset.owner ?? '';
          const collabs = (card.dataset.collaborators ?? '').split(',').filter(Boolean);
          const tags = (card.dataset.tags ?? '').split(',').filter(Boolean);

          const personOk = !state.person || owner === state.person || collabs.includes(state.person);
          const tagOk = !state.tag || tags.includes(state.tag);
          const textOk = !text || cardText.includes(text);

          card.style.display = personOk && tagOk && textOk ? '' : 'none';
        });

        // Update column counts
        document.querySelectorAll<HTMLElement>('[data-column]').forEach((col) => {
          const visible = col.querySelectorAll('.card:not([style*="display: none"])').length;
          const countEl = col.querySelector('.count');
          if (countEl) countEl.textContent = String(visible);
        });
      }

      function setActive(filterGroup: string, value: string) {
        document.querySelectorAll<HTMLButtonElement>(`[data-filter="${filterGroup}"]`).forEach((btn) => {
          btn.classList.toggle('is-active', btn.dataset.value === value);
        });
      }

      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter]');
        if (btn) {
          const group = btn.dataset.filter as 'person' | 'tag';
          const value = btn.dataset.value ?? '';
          state[group] = value;
          setActive(group, value);
          applyFilters();
          return;
        }
        if ((e.target as HTMLElement).closest('[data-clear]')) {
          state.person = '';
          state.tag = '';
          state.text = '';
          if (searchInput) searchInput.value = '';
          setActive('person', '');
          setActive('tag', '');
          applyFilters();
        }
      });

      searchInput?.addEventListener('input', () => {
        state.text = searchInput.value;
        applyFilters();
      });

      // ---------- Drag-and-drop between status columns ----------
      // Cards have `draggable="true"`. Each column body has `data-column="<status>"`.
      // On drop:
      //   1. Optimistically move the DOM node and update visible counts.
      //   2. POST /api/cards/:id/move.
      //   3. On error, snap the card back and surface a banner.
      //
      // No frameworks; HTML5 drag/drop fires plenty of events for this.

      let draggingCardId: string | null = null;
      let draggingFromStatus: string | null = null;

      document.addEventListener('dragstart', (e) => {
        const card = (e.target as HTMLElement).closest<HTMLElement>('.card');
        if (!card) return;
        draggingCardId = card.dataset.cardId ?? null;
        draggingFromStatus = card.dataset.status ?? null;
        card.classList.add('is-dragging');
        // Required for Firefox to let the drag start at all.
        e.dataTransfer?.setData('text/plain', draggingCardId ?? '');
        if (e.dataTransfer) e.dataTransfer.effectAllowed = 'move';
      });

      document.addEventListener('dragend', () => {
        document.querySelectorAll<HTMLElement>('.card.is-dragging').forEach((c) => c.classList.remove('is-dragging'));
        document.querySelectorAll<HTMLElement>('[data-column].drop-target').forEach((c) => c.classList.remove('drop-target'));
        draggingCardId = null;
        draggingFromStatus = null;
      });

      // Allow drop targets only when something kitsunebi-shaped is being dragged.
      function targetColumn(target: EventTarget | null): HTMLElement | null {
        if (!(target instanceof HTMLElement)) return null;
        return target.closest<HTMLElement>('[data-column]');
      }

      document.addEventListener('dragover', (e) => {
        if (!draggingCardId) return;
        const col = targetColumn(e.target);
        if (!col) return;
        e.preventDefault();
        if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
        col.classList.add('drop-target');
      });

      document.addEventListener('dragleave', (e) => {
        const col = targetColumn(e.target);
        if (!col) return;
        // Only un-highlight when actually leaving the column (relatedTarget is
        // outside it). Without this check, hovering between children flickers.
        const into = (e as DragEvent).relatedTarget as Node | null;
        if (into && col.contains(into)) return;
        col.classList.remove('drop-target');
      });

      document.addEventListener('drop', async (e) => {
        if (!draggingCardId) return;
        const col = targetColumn(e.target);
        if (!col) return;
        e.preventDefault();
        col.classList.remove('drop-target');

        const newStatus = col.dataset.column;
        if (!newStatus || newStatus === draggingFromStatus) return;

        const cardEl = document.querySelector<HTMLElement>(`.card[data-card-id="${CSS.escape(draggingCardId)}"]`);
        if (!cardEl) return;

        const sourceCol = document.querySelector<HTMLElement>(`[data-column="${CSS.escape(draggingFromStatus ?? '')}"]`);
        const targetBody = col.querySelector<HTMLElement>('.column-body');
        if (!targetBody) return;

        // Optimistic move.
        const cardId = draggingCardId;
        const originalStatusClass = `status-${draggingFromStatus}`;
        const newStatusClass = `status-${newStatus}`;
        cardEl.classList.remove(originalStatusClass);
        cardEl.classList.add(newStatusClass);
        cardEl.dataset.status = newStatus;
        // Drop the empty-state placeholder if present in the target.
        const emptyPlaceholder = targetBody.querySelector('.empty');
        if (emptyPlaceholder) emptyPlaceholder.remove();
        targetBody.appendChild(cardEl);
        updateColumnCount(sourceCol);
        updateColumnCount(col);
        cardEl.classList.add('drop-success');
        setTimeout(() => cardEl.classList.remove('drop-success'), 700);

        try {
          const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}/move`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus }),
          });
          if (!r.ok) throw new Error(`HTTP ${r.status}`);
        } catch (err) {
          // Snap back. Best-effort: put it where it came from; if the original
          // column collapsed in the meantime, leave it where it is and tell the user.
          console.error('move failed:', err);
          cardEl.classList.remove(newStatusClass);
          cardEl.classList.add(originalStatusClass);
          cardEl.dataset.status = draggingFromStatus ?? '';
          if (sourceCol) {
            const sourceBody = sourceCol.querySelector<HTMLElement>('.column-body');
            if (sourceBody) sourceBody.appendChild(cardEl);
            updateColumnCount(sourceCol);
            updateColumnCount(col);
          }
          alert(`Couldn't move card: ${err instanceof Error ? err.message : 'unknown error'}\nThe card was reverted.`);
        }
      });

      function updateColumnCount(col: HTMLElement | null) {
        if (!col) return;
        const count = col.querySelectorAll('.card').length;
        const countEl = col.querySelector('.count');
        if (countEl) countEl.textContent = String(count);
        // If the target now has zero cards, drop a "— quiet —" placeholder back in.
        const body = col.querySelector('.column-body');
        if (body && count === 0 && !body.querySelector('.empty')) {
          const empty = document.createElement('div');
          empty.className = 'empty';
          empty.textContent = '— quiet —';
          body.appendChild(empty);
        }
      }

      // Keyboard navigation:
      //   /       focus filter
      //   Escape  blur filter, or clear card focus
      //   j / ↓   next card
      //   k / ↑   previous card
      //   Enter   open focused card
      //   ?       show help
      let focusedIdx = -1;

      function visibleCards(): HTMLElement[] {
        return [...document.querySelectorAll<HTMLElement>('.card')].filter(
          (c) => c.style.display !== 'none'
        );
      }

      function focusCard(idx: number) {
        const cards = visibleCards();
        if (cards.length === 0) return;
        focusedIdx = ((idx % cards.length) + cards.length) % cards.length;
        cards.forEach((c, i) => c.classList.toggle('kbd-focus', i === focusedIdx));
        cards[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }

      function clearFocus() {
        document.querySelectorAll('.kbd-focus').forEach((c) => c.classList.remove('kbd-focus'));
        focusedIdx = -1;
      }

      document.addEventListener('keydown', (e) => {
        const inInput = e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement;

        if (e.key === '/' && !inInput) {
          e.preventDefault();
          searchInput?.focus();
          return;
        }
        if (e.key === 'Escape') {
          if (document.activeElement === searchInput) {
            searchInput!.blur();
          } else {
            clearFocus();
          }
          return;
        }
        if (inInput) return;

        if (e.key === 'j' || e.key === 'ArrowDown') {
          e.preventDefault();
          focusCard(focusedIdx + 1);
        } else if (e.key === 'k' || e.key === 'ArrowUp') {
          e.preventDefault();
          focusCard(focusedIdx - 1);
        } else if (e.key === 'Enter' && focusedIdx >= 0) {
          e.preventDefault();
          const cards = visibleCards();
          const card = cards[focusedIdx];
          const id = card?.dataset.cardId;
          if (id) window.location.href = `/cards/${id}/`;
        } else if (e.key === '?') {
          e.preventDefault();
          alert('keys:\n  /       filter\n  j / ↓   next card\n  k / ↑   previous\n  Enter   open\n  Esc     clear\n  ?       help');
        }
      });
    </script>

    <footer class="site-foot">
      <div class="foot-row">
        <div class="legend" aria-label="Status legend">
          <span class="legend-item"><span class="legend-flame lg-backlog"></span>backlog</span>
          <span class="legend-item"><span class="legend-flame lg-blocked"></span>blocked</span>
          <span class="legend-item"><span class="legend-flame lg-in_progress"></span>in progress</span>
          <span class="legend-item"><span class="legend-flame lg-done"></span>done</span>
        </div>
        <div class="foot-links">
          <a href="https://github.com/AdaInTheLab/kitsunebi" rel="noopener" target="_blank">github</a>
          <span class="divider">·</span>
          <a href="https://openhearth.kitsuneden.net" rel="noopener" target="_blank">openhearth</a>
        </div>
      </div>
      <div class="foot-row foot-row-bottom">
        <span class="foot-hint">
          Cards live as markdown in <code>cards/</code>.
          Keys: <kbd>/</kbd> filter · <kbd>j</kbd>/<kbd>k</kbd> nav · <kbd>Enter</kbd> open
        </span>
        <span class="divider">·</span>
        <span>Skulk persists eternal. 🦊</span>
      </div>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .site-head {
    margin-bottom: 2.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.5rem;
  }

  :global(.brand-flame) {
    color: var(--flame-in_progress);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    margin: 0;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .tagline {
    color: var(--text-dim);
    margin: 0 0 0.75rem 0;
    font-size: 0.95rem;
  }

  .stats {
    display: flex;
    gap: 0.55rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
  }

  .dot {
    opacity: 0.5;
  }

  .owners {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .owner-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.12rem 0.55rem 0.12rem 0.45rem;
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    font-size: 0.72rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: border-color 150ms ease, color 150ms ease;
  }

  .owner-pill:hover {
    border-color: var(--flame-in_progress);
    color: var(--text);
  }

  .owner-count {
    font-variant-numeric: tabular-nums;
    color: var(--flame-in_progress);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 0.8rem 1rem;
    background: rgba(23, 23, 28, 0.55);
    border: 1px solid var(--border-soft);
    border-radius: 8px;
    backdrop-filter: blur(6px);
  }

  #filter-search {
    flex: 1;
    min-width: 180px;
    background: var(--bg-0);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.4rem 0.7rem;
    font: inherit;
    font-size: 0.82rem;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  #filter-search:focus {
    outline: none;
    border-color: var(--flame-in_progress);
    box-shadow: 0 0 0 2px var(--flame-in_progress-glow);
  }

  #filter-search::placeholder {
    color: var(--text-soft);
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: center;
  }

  .filter-pill {
    background: var(--bg-0);
    color: var(--text-dim);
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    padding: 0.22rem 0.7rem;
    font: inherit;
    font-size: 0.74rem;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  .filter-pill:hover {
    color: var(--text);
    border-color: var(--flame-in_progress);
  }

  .filter-pill.is-active {
    color: var(--flame-in_progress);
    border-color: var(--flame-in_progress);
    background: var(--flame-in_progress-glow);
  }

  .tag-filter {
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .filter-clear {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--text-soft);
    cursor: pointer;
    font: inherit;
    font-size: 0.74rem;
    padding: 0.22rem 0.5rem;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .filter-clear:hover {
    color: var(--flame-blocked);
    border-bottom-color: var(--flame-blocked);
  }

  .board {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 1100px) {
    .board { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 640px) {
    .board { grid-template-columns: 1fr; }
  }

  /* While dragging, show columns as receptive. The :global() escapes
     scoped styles to reach the [data-column] elements rendered by Column.astro. */
  :global([data-column].drop-target .column-body) {
    background: rgba(255, 255, 255, 0.025);
    box-shadow: inset 0 0 0 1px var(--flame-in_progress-glow), inset 0 0 32px -8px var(--flame-in_progress-glow);
    border-radius: 6px;
    transition: background 120ms ease, box-shadow 120ms ease;
  }

  /* Brief pulse confirming a successful drop. */
  :global(.card.drop-success) {
    animation: dropPulse 700ms ease-out;
  }

  @keyframes dropPulse {
    0%   { box-shadow: 0 0 0 0 var(--flame-glow), 0 0 0 1px var(--flame); }
    60%  { box-shadow: 0 0 22px 4px var(--flame-glow), 0 0 0 1px var(--flame); }
    100% { box-shadow: 0 1px 0 var(--flame-glow) inset, 0 0 18px -8px var(--flame-glow); }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.card.drop-success) { animation: none; }
  }

  .site-foot {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-soft);
    color: var(--text-soft);
    font-size: 0.78rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .foot-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
  }

  .foot-row-bottom {
    padding-top: 0.7rem;
    border-top: 1px dashed var(--border-soft);
    opacity: 0.85;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-dim);
    font-size: 0.76rem;
  }

  .legend-flame {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    display: inline-block;
  }

  .lg-backlog { background: var(--flame-backlog); box-shadow: 0 0 6px var(--flame-backlog-glow); }
  .lg-blocked { background: var(--flame-blocked); box-shadow: 0 0 6px var(--flame-blocked-glow); }
  .lg-in_progress { background: var(--flame-in_progress); box-shadow: 0 0 6px var(--flame-in_progress-glow); }
  .lg-done { background: var(--flame-done); box-shadow: 0 0 6px var(--flame-done-glow); }

  .foot-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .foot-links a {
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .foot-links a:hover {
    color: var(--flame-in_progress);
    border-bottom-color: var(--flame-in_progress);
  }

  .foot-hint {
    flex: 1;
    min-width: 0;
  }

  .divider {
    opacity: 0.4;
  }
</style>
