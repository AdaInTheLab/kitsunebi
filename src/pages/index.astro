---
import { getCollection } from 'astro:content';
import { readdirSync } from 'node:fs';
import Layout from '../layouts/Layout.astro';
import Column from '../components/Column.astro';
import Flame from '../components/Flame.astro';
import { maybeSweepArchived } from '../lib/archive-sweep';
import { countComments } from '../lib/comments-fs';

// Auto-archive sweep ~ debounced 1h via stamp file, no-op on most page loads.
// Runs before getCollection so any cards moved to `archived` reflect immediately.
await maybeSweepArchived();

const allCards = await getCollection('cards');

// Sanity check: Astro silently drops cards/*.md files that fail schema
// validation, with no build warning. (Cost us a day where kc-troubleshooting-docs
// vanished from the live board because of `completed: null`.)
//
// We compare the build-time-loaded collection against the live on-disk file
// list. Two distinct cases produce a mismatch:
//
//   1. A card's frontmatter is broken ~ Astro silently dropped it. We want
//      to surface this loudly.
//   2. A card was created on disk AFTER the last build (e.g. via the agent
//      API on prod, between deploys). That card's frontmatter is presumably
//      fine, just newer than the bundled collection. We DON'T want to crash
//      the page over this ~ the next deploy picks it up. (Crashing here was
//      our 500 on 2026-04-27 when Sage created `deep-work-window-design`
//      via the API and the site went down for everyone.)
//
// Net behavior: log a single console warning listing every missing id; the
// page still renders the cards we have. Real broken-frontmatter bugs surface
// in the warn line; new-card-since-build mismatches resolve themselves on
// the next deploy without taking the site down.
const onDisk = readdirSync('./cards').filter((f) => f.endsWith('.md')).map((f) => f.replace(/\.md$/, ''));
const loadedIds = new Set(allCards.map((c) => c.id));
const missing = onDisk.filter((id) => !loadedIds.has(id));
if (missing.length > 0) {
  console.warn(
    `[kitsunebi] ${missing.length} card(s) on disk are not in the bundled collection: ${missing.join(', ')}.\n` +
    `  Either added since the last build (next deploy fixes), or have invalid frontmatter (check src/content.config.ts).`
  );
}

// Sort: explicit `order:` wins (ascending); cards without one fall back to
// newer-`created`-first. Mixed columns interleave correctly because we compute
// each card's "effective order" as either its explicit order or `-createdMs`,
// and sort by that. Same comparator runs server-rendered and client-side
// (the drag-drop logic uses the matching helper from src/lib/sort-cards.ts).
const sorted = allCards.slice().sort((a, b) => {
  return effectiveOrder(a) - effectiveOrder(b);
});

function effectiveOrder(card: (typeof allCards)[number]): number {
  if (typeof card.data.order === 'number') return card.data.order;
  // Fallback: newer cards float to the top. We negate the timestamp so the
  // sort stays "ascending = top of column", matching explicit-order semantics.
  const created = card.data.created ? Date.parse(card.data.created) : 0;
  return -created;
}

const columns = [
  { status: 'backlog' as const, label: 'Backlog' },
  { status: 'blocked' as const, label: 'Blocked' },
  { status: 'in_progress' as const, label: 'In Progress' },
  { status: 'done' as const, label: 'Done' },
];

const cardsByStatus = Object.fromEntries(
  columns.map((c) => [c.status, sorted.filter((card) => card.data.status === c.status)])
);

const totalActive = cardsByStatus.in_progress.length + cardsByStatus.blocked.length + cardsByStatus.backlog.length;

// Owner breakdown ~ only count active cards (not done/archived)
const activeCards = sorted.filter((c) => c.data.status !== 'done' && c.data.status !== 'archived');
const ownerCounts = new Map<string, number>();
for (const c of activeCards) {
  ownerCounts.set(c.data.owner, (ownerCounts.get(c.data.owner) ?? 0) + 1);
}
const ownerList = [...ownerCounts.entries()].sort((a, b) => b[1] - a[1]);

// All unique tags, for the filter bar
const tagSet = new Set<string>();
for (const c of sorted) for (const t of c.data.tags) tagSet.add(t);
const allTags = [...tagSet].sort();

// All unique people (owners + collaborators)
const peopleSet = new Set<string>();
for (const c of sorted) {
  peopleSet.add(c.data.owner);
  for (const p of c.data.collaborators) peopleSet.add(p);
}
const allPeople = [...peopleSet].sort();

// Comment counts per card. One filesystem read per card; cheap relative
// to the rest of SSR with a few dozen cards on the board.
const commentCounts = new Map<string, number>(
  await Promise.all(sorted.map(async (c) => [c.id, await countComments(c.id)] as [string, number])),
);
---

<Layout title="kitsunebi ~ the Skulk's board">
  <main>
    <header class="site-head">
      <div class="brand">
        <Flame size={28} class="brand-flame" />
        <h1>kitsunebi</h1>
      </div>
      <p class="tagline">
        A board for the Skulk. Each card a flame, the whole a procession of lanterns.
      </p>
      <div class="stats">
        <span>{allCards.length} cards total</span>
        <span class="dot">·</span>
        <span>{totalActive} active</span>
        <span class="dot">·</span>
        <span>{cardsByStatus.done.length} shipped</span>
        <span class="dot">·</span>
        <a href="/activity/" class="archive-link">activity →</a>
        <span class="dot">·</span>
        <a href="/archive/" class="archive-link">archive →</a>
      </div>
      {ownerList.length > 0 && (
        <div class="owners" aria-label="Active cards by owner">
          {ownerList.map(([owner, count]) => (
            <a href={`/people/${owner}/`} class="owner-pill">
              <span class="owner-name">{owner}</span>
              <span class="owner-count">{count}</span>
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="filter-bar" role="search" aria-label="Filter cards">
      <input
        type="search"
        id="filter-search"
        placeholder="filter by text (press /)"
        aria-label="Filter cards by text"
      />
      <div class="filter-pills">
        <button type="button" class="filter-pill is-active" data-filter="person" data-value="">all people</button>
        {allPeople.map((p) => (
          <button type="button" class="filter-pill" data-filter="person" data-value={p}>🦊 {p}</button>
        ))}
      </div>
      {allTags.length > 0 && (
        <div class="filter-pills tag-pills">
          <button type="button" class="filter-pill is-active" data-filter="tag" data-value="">all tags</button>
          {allTags.map((t) => (
            <button type="button" class="filter-pill tag-filter" data-filter="tag" data-value={t}>#{t}</button>
          ))}
        </div>
      )}
      <button type="button" class="filter-clear" data-clear>clear</button>
    </div>

    <div class="board">
      {columns.map((c) => (
        <Column status={c.status} label={c.label} cards={cardsByStatus[c.status]} commentCounts={commentCounts} />
      ))}
    </div>

    <script>
      type FilterState = { person: string; tag: string; text: string };
      const state: FilterState = { person: '', tag: '', text: '' };

      const searchInput = document.getElementById('filter-search') as HTMLInputElement | null;
      const clearBtn = document.querySelector<HTMLButtonElement>('[data-clear]');

      function applyFilters() {
        const text = state.text.trim().toLowerCase();
        document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
          const cardText = card.textContent?.toLowerCase() ?? '';
          const owner = card.dataset.owner ?? '';
          const collabs = (card.dataset.collaborators ?? '').split(',').filter(Boolean);
          const tags = (card.dataset.tags ?? '').split(',').filter(Boolean);

          const personOk = !state.person || owner === state.person || collabs.includes(state.person);
          const tagOk = !state.tag || tags.includes(state.tag);
          const textOk = !text || cardText.includes(text);

          card.style.display = personOk && tagOk && textOk ? '' : 'none';
        });

        // Update column counts
        document.querySelectorAll<HTMLElement>('[data-column]').forEach((col) => {
          const visible = col.querySelectorAll('.card:not([style*="display: none"])').length;
          const countEl = col.querySelector('.count');
          if (countEl) countEl.textContent = String(visible);
        });
      }

      function setActive(filterGroup: string, value: string) {
        document.querySelectorAll<HTMLButtonElement>(`[data-filter="${filterGroup}"]`).forEach((btn) => {
          btn.classList.toggle('is-active', btn.dataset.value === value);
        });
      }

      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-filter]');
        if (btn) {
          const group = btn.dataset.filter as 'person' | 'tag';
          const value = btn.dataset.value ?? '';
          state[group] = value;
          setActive(group, value);
          applyFilters();
          return;
        }
        if ((e.target as HTMLElement).closest('[data-clear]')) {
          state.person = '';
          state.tag = '';
          state.text = '';
          if (searchInput) searchInput.value = '';
          setActive('person', '');
          setActive('tag', '');
          applyFilters();
        }
      });

      searchInput?.addEventListener('input', () => {
        state.text = searchInput.value;
        applyFilters();
      });

      // ---------- Drag-and-drop with status moves AND intra-column sort ----------
      // Cards have `draggable="true"`. Each column body has `data-column="<status>"`.
      // On dragover we figure out the *insertion point* ~ between which two
      // sibling cards the drop would land ~ and on drop we compute a new
      // floating-point `order` as the midpoint of those neighbors' "effective
      // orders" (explicit `data-order` if set, else `-Date.parse(data-created)`
      // so newer-first stays the default for unordered cards).
      //
      // Result: a single API call per drop ({status, order}), one card-file
      // write on the server, one git-sync commit. No batch renumbering.

      let draggingCardId: string | null = null;
      let draggingFromStatus: string | null = null;

      document.addEventListener('dragstart', (e) => {
        const card = (e.target as HTMLElement).closest<HTMLElement>('.card');
        if (!card) return;
        draggingCardId = card.dataset.cardId ?? null;
        draggingFromStatus = card.dataset.status ?? null;
        card.classList.add('is-dragging');
        // Required for Firefox to let the drag start at all.
        e.dataTransfer?.setData('text/plain', draggingCardId ?? '');
        if (e.dataTransfer) e.dataTransfer.effectAllowed = 'move';
      });

      document.addEventListener('dragend', () => {
        document.querySelectorAll<HTMLElement>('.card.is-dragging').forEach((c) => c.classList.remove('is-dragging'));
        document.querySelectorAll<HTMLElement>('[data-column].drop-target').forEach((c) => c.classList.remove('drop-target'));
        clearDropIndicator();
        draggingCardId = null;
        draggingFromStatus = null;
      });

      function targetColumn(target: EventTarget | null): HTMLElement | null {
        if (!(target instanceof HTMLElement)) return null;
        return target.closest<HTMLElement>('[data-column]');
      }

      /** Effective order for sort comparisons. Mirrors index.astro's server-side sort. */
      function effectiveOrder(card: HTMLElement): number {
        const raw = card.dataset.order;
        if (raw && raw.trim() !== '') {
          const n = Number(raw);
          if (Number.isFinite(n)) return n;
        }
        const created = card.dataset.created ? Date.parse(card.dataset.created) : 0;
        return -created;
      }

      /**
       * Where, in this column, would a drop at this Y coordinate land?
       * Returns `null` for "after the last card" (and an empty column).
       */
      function findDropAfter(col: HTMLElement, clientY: number): HTMLElement | null {
        const cards = [...col.querySelectorAll<HTMLElement>('.card:not(.is-dragging)')];
        // Walk top to bottom; the first card whose vertical midpoint is
        // *below* the cursor is the one we'd land before.
        for (const c of cards) {
          const rect = c.getBoundingClientRect();
          if (clientY < rect.top + rect.height / 2) return c;
        }
        return null; // dropped past the last card → append
      }

      /** A thin orange line between cards showing where the drop will land. */
      let dropIndicator: HTMLElement | null = null;
      function showDropIndicator(col: HTMLElement, before: HTMLElement | null) {
        clearDropIndicator();
        const body = col.querySelector<HTMLElement>('.column-body');
        if (!body) return;
        dropIndicator = document.createElement('div');
        dropIndicator.className = 'drop-indicator';
        if (before) body.insertBefore(dropIndicator, before);
        else body.appendChild(dropIndicator);
      }
      function clearDropIndicator() {
        dropIndicator?.remove();
        dropIndicator = null;
      }

      document.addEventListener('dragover', (e) => {
        if (!draggingCardId) return;
        const col = targetColumn(e.target);
        if (!col) return;
        e.preventDefault();
        if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
        col.classList.add('drop-target');
        // Compute and render the would-be drop position so the user can see
        // exactly where the card will land before they release.
        const before = findDropAfter(col, e.clientY);
        showDropIndicator(col, before);
      });

      document.addEventListener('dragleave', (e) => {
        const col = targetColumn(e.target);
        if (!col) return;
        // Only un-highlight when actually leaving the column (relatedTarget is
        // outside it). Without this check, hovering between children flickers.
        const into = (e as DragEvent).relatedTarget as Node | null;
        if (into && col.contains(into)) return;
        col.classList.remove('drop-target');
        clearDropIndicator();
      });

      document.addEventListener('drop', async (e) => {
        if (!draggingCardId) return;
        const col = targetColumn(e.target);
        if (!col) return;
        e.preventDefault();
        col.classList.remove('drop-target');

        const newStatus = col.dataset.column;
        if (!newStatus) {
          clearDropIndicator();
          return;
        }

        const cardEl = document.querySelector<HTMLElement>(`.card[data-card-id="${CSS.escape(draggingCardId)}"]`);
        if (!cardEl) {
          clearDropIndicator();
          return;
        }

        const sourceCol = document.querySelector<HTMLElement>(
          `[data-column="${CSS.escape(draggingFromStatus ?? '')}"]`
        );
        const targetBody = col.querySelector<HTMLElement>('.column-body');
        if (!targetBody) {
          clearDropIndicator();
          return;
        }

        // Where in the target column does this drop land?
        const before = findDropAfter(col, (e as DragEvent).clientY);

        // Don't write if it's a no-op: same column AND no actual position
        // change (target slot's neighbors are exactly this card already).
        const isSameColumn = newStatus === draggingFromStatus;
        if (isSameColumn) {
          const cards = [...targetBody.querySelectorAll<HTMLElement>('.card')];
          const idx = cards.indexOf(cardEl);
          const beforeIdx = before ? cards.indexOf(before) : cards.length;
          if (beforeIdx === idx || beforeIdx === idx + 1) {
            clearDropIndicator();
            return;
          }
        }

        // Optimistic DOM move (status class swap + reposition).
        const cardId = draggingCardId;
        const originalStatusClass = `status-${draggingFromStatus}`;
        const newStatusClass = `status-${newStatus}`;
        const originalNextSibling = cardEl.nextSibling; // for snap-back
        const originalParent = cardEl.parentElement;
        const originalDataOrder = cardEl.dataset.order ?? '';

        cardEl.classList.remove(originalStatusClass);
        cardEl.classList.add(newStatusClass);
        cardEl.dataset.status = newStatus;

        const emptyPlaceholder = targetBody.querySelector('.empty');
        if (emptyPlaceholder) emptyPlaceholder.remove();
        if (before) targetBody.insertBefore(cardEl, before);
        else targetBody.appendChild(cardEl);

        clearDropIndicator();
        updateColumnCount(sourceCol);
        updateColumnCount(col);
        cardEl.classList.add('drop-success');
        setTimeout(() => cardEl.classList.remove('drop-success'), 700);

        // Compute the new `order` as the midpoint of the cards now immediately
        // above and below the dragged card in the target column. We look at
        // the post-move DOM, EXCLUDING the dragged card itself.
        const siblings = [...targetBody.querySelectorAll<HTMLElement>('.card')].filter((c) => c !== cardEl);
        const cardEls = [...targetBody.querySelectorAll<HTMLElement>('.card')];
        const myIdx = cardEls.indexOf(cardEl);
        const above = myIdx > 0 ? cardEls[myIdx - 1] : null;
        const below = myIdx < cardEls.length - 1 ? cardEls[myIdx + 1] : null;
        // (siblings is the same set as above/below context; kept for readability)
        void siblings;

        let newOrder: number;
        if (above && below) {
          newOrder = (effectiveOrder(above) + effectiveOrder(below)) / 2;
        } else if (above) {
          newOrder = effectiveOrder(above) + 1;
        } else if (below) {
          newOrder = effectiveOrder(below) - 1;
        } else {
          newOrder = 0;
        }

        cardEl.dataset.order = String(newOrder);

        try {
          const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}/move`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus, order: newOrder }),
          });
          if (!r.ok) throw new Error(`HTTP ${r.status}`);
        } catch (err) {
          console.error('move failed:', err);
          // Snap back: status class, dataset, position, order.
          cardEl.classList.remove(newStatusClass);
          cardEl.classList.add(originalStatusClass);
          cardEl.dataset.status = draggingFromStatus ?? '';
          cardEl.dataset.order = originalDataOrder;
          if (originalParent) {
            originalParent.insertBefore(cardEl, originalNextSibling);
            updateColumnCount(sourceCol);
            updateColumnCount(col);
          }
          alert(`Couldn't move card: ${err instanceof Error ? err.message : 'unknown error'}\nThe card was reverted.`);
        }
      });

      function updateColumnCount(col: HTMLElement | null) {
        if (!col) return;
        const count = col.querySelectorAll('.card').length;
        const countEl = col.querySelector('.count');
        if (countEl) countEl.textContent = String(count);
        // If the target now has zero cards, drop a "~ quiet ~" placeholder back in.
        const body = col.querySelector('.column-body');
        if (body && count === 0 && !body.querySelector('.empty')) {
          const empty = document.createElement('div');
          empty.className = 'empty';
          empty.textContent = '~ quiet ~';
          body.appendChild(empty);
        }
      }

      // Keyboard navigation:
      //   /       focus filter
      //   Escape  blur filter, or clear card focus
      //   j / ↓   next card
      //   k / ↑   previous card
      //   Enter   open focused card
      //   ?       show help
      let focusedIdx = -1;

      function visibleCards(): HTMLElement[] {
        return [...document.querySelectorAll<HTMLElement>('.card')].filter(
          (c) => c.style.display !== 'none'
        );
      }

      function focusCard(idx: number) {
        const cards = visibleCards();
        if (cards.length === 0) return;
        focusedIdx = ((idx % cards.length) + cards.length) % cards.length;
        cards.forEach((c, i) => c.classList.toggle('kbd-focus', i === focusedIdx));
        cards[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }

      function clearFocus() {
        document.querySelectorAll('.kbd-focus').forEach((c) => c.classList.remove('kbd-focus'));
        focusedIdx = -1;
      }

      document.addEventListener('keydown', (e) => {
        const inInput = e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement;

        if (e.key === '/' && !inInput) {
          e.preventDefault();
          searchInput?.focus();
          return;
        }
        if (e.key === 'Escape') {
          if (document.activeElement === searchInput) {
            searchInput!.blur();
          } else {
            clearFocus();
          }
          return;
        }
        if (inInput) return;

        if (e.key === 'j' || e.key === 'ArrowDown') {
          e.preventDefault();
          focusCard(focusedIdx + 1);
        } else if (e.key === 'k' || e.key === 'ArrowUp') {
          e.preventDefault();
          focusCard(focusedIdx - 1);
        } else if (e.key === 'Enter' && focusedIdx >= 0) {
          e.preventDefault();
          const cards = visibleCards();
          const card = cards[focusedIdx];
          const id = card?.dataset.cardId;
          if (id) window.location.href = `/cards/${id}/`;
        } else if (e.key === '?') {
          e.preventDefault();
          alert('keys:\n  /       filter\n  j / ↓   next card\n  k / ↑   previous\n  Enter   open\n  Esc     clear\n  ?       help');
        }
      });

      // ---------- Image thumbnails on cards ----------
      // Card-body images render as bare <img> from markdown. Wrap each in a
      // `.thumb` span and append a ✕ button that calls
      // `DELETE /api/cards/:id/attachments?file=<basename>`.
      function wrapThumbnails() {
        document.querySelectorAll<HTMLElement>('.card .card-body img, .card .card-body video').forEach((el) => {
          if (el.parentElement?.classList.contains('thumb')) return;
          const card = el.closest<HTMLElement>('.card');
          const cardId = card?.dataset.cardId ?? '';
          const src = (el as HTMLImageElement | HTMLVideoElement).getAttribute('src') ?? '';
          const expectedPrefix = `/attachments/${cardId}/`;
          if (!cardId || !src.startsWith(expectedPrefix)) {
            // Not an attachment we own ~ skip the remove affordance, but still
            // make it 1:1 by wrapping (so layout is consistent).
            const wrap = document.createElement('span');
            wrap.className = 'thumb';
            el.replaceWith(wrap);
            wrap.appendChild(el);
            return;
          }
          const filename = decodeURIComponent(src.slice(expectedPrefix.length));

          const wrap = document.createElement('span');
          wrap.className = 'thumb';
          el.replaceWith(wrap);
          wrap.appendChild(el);

          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'thumb-remove';
          btn.setAttribute('aria-label', `Remove ${filename}`);
          btn.title = `Remove ${filename}`;
          btn.textContent = '✕';
          btn.addEventListener('click', async (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (!window.confirm(`Remove ${filename}?`)) return;
            btn.disabled = true;
            try {
              const r = await fetch(
                `/api/cards/${encodeURIComponent(cardId)}/attachments?file=${encodeURIComponent(filename)}`,
                { method: 'DELETE' },
              );
              if (!r.ok) {
                const errBody = await r.text();
                throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
              }
              wrap.remove();
            } catch (err) {
              console.error('attachment delete failed:', err);
              alert(`Couldn't remove image: ${err instanceof Error ? err.message : 'unknown error'}`);
              btn.disabled = false;
            }
          });
          // The card itself is draggable; without this the mousedown-then-drag
          // on the button would start dragging the whole card.
          btn.addEventListener('mousedown', (e) => e.stopPropagation());
          btn.addEventListener('dragstart', (e) => e.preventDefault());
          wrap.appendChild(btn);
        });
      }
      wrapThumbnails();
    </script>

    <footer class="site-foot">
      <div class="foot-row">
        <div class="legend" aria-label="Status legend">
          <span class="legend-item"><span class="legend-flame lg-backlog"></span>backlog</span>
          <span class="legend-item"><span class="legend-flame lg-blocked"></span>blocked</span>
          <span class="legend-item"><span class="legend-flame lg-in_progress"></span>in progress</span>
          <span class="legend-item"><span class="legend-flame lg-done"></span>done</span>
        </div>
        <div class="foot-links">
          <a href="https://github.com/AdaInTheLab/kitsunebi" rel="noopener" target="_blank">github</a>
          <span class="divider">·</span>
          <a href="https://openhearth.kitsuneden.net" rel="noopener" target="_blank">openhearth</a>
        </div>
      </div>
      <div class="foot-row foot-row-bottom">
        <span class="foot-hint">
          Cards live as markdown in <code>cards/</code>.
          Keys: <kbd>/</kbd> filter · <kbd>j</kbd>/<kbd>k</kbd> nav · <kbd>Enter</kbd> open
        </span>
        <span class="divider">·</span>
        <span>Skulk persists eternal. 🦊</span>
      </div>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .site-head {
    margin-bottom: 2.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.5rem;
  }

  :global(.brand-flame) {
    color: var(--flame-in_progress);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    margin: 0;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .tagline {
