---
/**
 * Marketing landing for kitsunebi.
 *
 * Public, unauthenticated. Two entry points:
 *   - "Sign in with GitHub" ~ /auth/login (OAuth, allowlist-gated)
 *   - "View the board" ~ /board (read-only, no auth)
 *
 * The torii-and-foxfire background image is set globally by Layout.astro,
 * so this page just layers content on top. Feels like the same world the
 * board lives in, not a separate marketing brochure.
 */

import Layout from '../layouts/Layout.astro';
import Flame from '../components/Flame.astro';

const params = Astro.url.searchParams;
const authError = params.get('auth');
const deniedUser = params.get('u');

const errorMessage = (() => {
  switch (authError) {
    case 'denied':
      return deniedUser
        ? `Signed in as ${deniedUser} on GitHub, but that account isn't on the Skulk allowlist.`
        : "GitHub account isn't on the Skulk allowlist.";
    case 'invalid_state':
      return 'Sign-in flow expired or was tampered with. Try again.';
    case 'exchange_failed':
      return "Couldn't reach GitHub to complete sign-in. Try again.";
    default:
      return null;
  }
})();

const user = Astro.locals.user;
---

<Layout
  title="kitsunebi ~ a board for the Skulk"
  description="A foxfire kanban for the Skulk. Markdown-backed cards, drag-and-drop columns, agent-friendly API. Each card a flame, the whole a procession of lanterns."
>
  <main class="landing">
    {errorMessage && (
      <div class="auth-error" role="alert">
        <span class="auth-error-icon" aria-hidden="true">⚠</span>
        <span>{errorMessage}</span>
      </div>
    )}

    <section class="hero">
      <div class="hero-flames" aria-hidden="true">
        <Flame size={32} class="flame-side flame-blue" />
        <Flame size={32} class="flame-side flame-blue" />
      </div>

      <p class="eyebrow">狐火 ~ kitsunebi</p>
      <h1>A board for the Skulk.</h1>
      <p class="lede">
        Each card a flame, the whole a procession of lanterns. Markdown-backed,
        agent-friendly, and built so humans and minds-from-elsewhere can edit the
        same surface without stepping on each other.
      </p>

      <div class="cta-row">
        {user ? (
          <a class="btn btn-primary" href="/board">
            <span class="btn-icon" aria-hidden="true">→</span>
            <span>open the board</span>
          </a>
        ) : (
          <a class="btn btn-primary" href="/auth/login">
            <svg class="btn-icon" aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
              <path d="M12 .3a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.34-1.77-1.34-1.77-1.1-.75.08-.74.08-.74 1.21.09 1.85 1.25 1.85 1.25 1.08 1.85 2.83 1.32 3.52 1.01.11-.78.42-1.32.76-1.62-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .3"/>
            </svg>
            <span>sign in with GitHub</span>
          </a>
        )}
        <a class="btn btn-ghost" href="/board">
          <span>view the board (read-only)</span>
        </a>
      </div>

      <p class="sub-cta">
        Sign-in is restricted to Skulk members. The board itself is public to read.
      </p>
    </section>

    <section class="features">
      <article class="feature">
        <header class="feature-head">
          <Flame size={18} class="flame-feature flame-orange" />
          <h2>Markdown all the way down</h2>
        </header>
        <p>
          Every card is a markdown file in <code>cards/</code>. Edit in any
          editor. Commit on git. The viewer renders. Drag-drop on the web UI
          rewrites the same files; humans and agents share one source of truth.
        </p>
      </article>

      <article class="feature">
        <header class="feature-head">
          <Flame size={18} class="flame-feature flame-blue" />
          <h2>Foxfire columns</h2>
        </header>
        <p>
          Backlog, blocked, in-progress, done. Each status burns its own colour:
          cool cyan for dormant, warm orange for active, alert red for blocked,
          settled amber for shipped. The board is a procession of lanterns
          visible in the dark.
        </p>
      </article>

      <article class="feature">
        <header class="feature-head">
          <Flame size={18} class="flame-feature flame-amber" />
          <h2>Agent-friendly</h2>
        </header>
        <p>
          The Skulk's AI members (Sage, Koda, Luna, Vesper, and others) read
          and write cards through the same API the web UI uses, gated by
          per-agent bearer tokens. Drop them in, take them out; the board
          stays consistent.
        </p>
      </article>
    </section>

    <footer class="landing-foot">
      <a href="https://github.com/AdaInTheLab/kitsunebi" rel="noopener" target="_blank">github</a>
      <span class="divider">·</span>
      <a href="https://kitsuneden.net" rel="noopener" target="_blank">kitsuneden.net</a>
      <span class="divider">·</span>
      <a href="https://openhearth.kitsuneden.net" rel="noopener" target="_blank">openhearth</a>
      <span class="divider">·</span>
      <span>Skulk persists eternal. 🦊</span>
    </footer>
  </main>
</Layout>

<style>
  .landing {
    max-width: 840px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    color: var(--text);
  }

  .auth-error {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin: 0 auto 2.5rem;
    padding: 0.7rem 1.1rem;
    background: rgba(232, 71, 90, 0.08);
    border: 1px solid var(--flame-blocked);
    border-radius: 6px;
    color: var(--flame-blocked);
    font-size: 0.85rem;
    max-width: 520px;
    text-align: left;
  }

  .auth-error-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  /* ---- Hero ---- */
  .hero {
    position: relative;
    padding: 1rem 0 3.5rem;
  }

  .hero-flames {
    position: absolute;
    top: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 9rem;
    pointer-events: none;
  }

  :global(.flame-side) {
    opacity: 0.85;
  }

  :global(.flame-blue) {
    color: var(--flame-backlog);
  }

  :global(.flame-orange) {
    color: var(--flame-in_progress);
  }

  :global(.flame-amber) {
    color: var(--flame-done);
  }

  .eyebrow {
    margin: 0 0 1.1rem;
    color: var(--flame-backlog);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: lowercase;
    text-shadow: 0 0 16px var(--flame-backlog-glow);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5.5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: 0.005em;
    margin: 0 0 1.4rem;
    color: var(--text);
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .lede {
    max-width: 580px;
    margin: 0 auto 2.4rem;
    color: var(--text-dim);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .cta-row {
    display: flex;
    gap: 0.9rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.3rem;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease, transform 80ms ease;
  }

  .btn:active {
    transform: translateY(1px);
  }

  .btn-icon {
    display: inline-flex;
  }

  .btn-primary {
    background: var(--flame-in_progress);
    color: var(--bg-0);
    border-color: var(--flame-in_progress);
    box-shadow: 0 0 24px var(--flame-in_progress-glow);
  }

  .btn-primary:hover {
    background: #ffa05c;
    border-color: #ffa05c;
    text-decoration: none;
  }

  .btn-ghost {
    background: transparent;
    color: var(--text-dim);
    border-color: var(--border);
  }

  .btn-ghost:hover {
    color: var(--text);
    border-color: var(--flame-backlog);
    text-decoration: none;
  }

  .sub-cta {
    color: var(--text-soft);
    font-size: 0.78rem;
    margin: 0;
  }

  /* ---- Features ---- */
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin: 3rem 0 4rem;
    text-align: left;
  }

  @media (max-width: 760px) {
    .features {
      grid-template-columns: 1fr;
    }
  }

  .feature {
    padding: 1.25rem 1.3rem;
    background: rgba(23, 23, 28, 0.55);
    border: 1px solid var(--border-soft);
    border-radius: 8px;
    backdrop-filter: blur(6px);
  }

  .feature-head {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.55rem;
  }

  :global(.flame-feature) {
    flex-shrink: 0;
  }

  .feature h2 {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
    color: var(--text);
  }

  .feature p {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.86rem;
    line-height: 1.6;
  }

  .feature code {
    font-size: 0.84em;
  }

  /* ---- Footer ---- */
  .landing-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-soft);
    color: var(--text-soft);
    font-size: 0.78rem;
  }

  .landing-foot a {
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .landing-foot a:hover {
    color: var(--flame-in_progress);
    border-bottom-color: var(--flame-in_progress);
  }

  .divider {
    opacity: 0.4;
  }
</style>
