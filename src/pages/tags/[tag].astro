---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import Flame from '../../components/Flame.astro';

// Server-rendered: filter cards by tag at request time. Same fresh-from-disk
// property as the rest of the site post-server-mode switch.
const { tag } = Astro.params;
if (!tag) {
  return new Response('Not Found', { status: 404 });
}
const allCards = await getCollection('cards');
const cards = allCards.filter((c) => c.data.tags?.includes(tag));
if (cards.length === 0) {
  return new Response('Not Found', { status: 404 });
}

const statusOrder = ['in_progress', 'blocked', 'backlog', 'done', 'archived'];
const sorted = cards.slice().sort((a, b) => {
  const sa = statusOrder.indexOf(a.data.status);
  const sb = statusOrder.indexOf(b.data.status);
  if (sa !== sb) return sa - sb;
  return (b.data.created || '').localeCompare(a.data.created || '');
});
---

<Layout title={`#${tag} — kitsunebi`} description={`Cards tagged #${tag}`}>
  <main>
    <nav class="breadcrumb">
      <a href="/">← back to board</a>
    </nav>

    <header class="list-head">
      <div class="list-brand">
        <Flame size={22} class="brand-flame" />
        <h1>#{tag}</h1>
      </div>
      <p class="count">{cards.length} card{cards.length === 1 ? '' : 's'}</p>
    </header>

    <div class="cards">
      {sorted.map((card, i) => <Card card={card} index={i} />)}
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    margin-bottom: 1.8rem;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.85rem;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .breadcrumb a:hover {
    color: var(--flame-in_progress);
    border-bottom-color: var(--flame-in_progress);
  }

  .list-head {
    margin-bottom: 2rem;
  }

  .list-brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.4rem;
  }

  :global(.brand-flame) {
    color: var(--flame-in_progress);
  }

  h1 {
    font-family: var(--font-mono);
    font-size: 2rem;
    margin: 0;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .count {
    color: var(--text-soft);
    font-size: 0.82rem;
    margin: 0;
  }

  .cards {
    display: flex;
    flex-direction: column;
  }
</style>
