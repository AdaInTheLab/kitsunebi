---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Flame from '../../components/Flame.astro';

// Server-rendered. We read the card from disk on every request so post-API
// mutations (drag-drop, inline edit) show up immediately without a rebuild.
const { id } = Astro.params;
if (!id) {
  return new Response('Not Found', { status: 404 });
}
const card = await getEntry('cards', id);
if (!card) {
  return new Response('Not Found', { status: 404 });
}
const { Content } = await render(card);
const data = card.data;

const statusLabels: Record<string, string> = {
  backlog: 'Backlog',
  blocked: 'Blocked',
  in_progress: 'In Progress',
  done: 'Done',
  archived: 'Archived',
};

const due = data.due ? new Date(data.due) : null;
const created = data.created ? new Date(data.created) : null;
const completed = data.completed ? new Date(data.completed) : null;

const fmt = (d: Date | null) =>
  d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
---

<Layout title={`${data.title} — kitsunebi`} description={`${statusLabels[data.status]} · owned by ${data.owner}`}>
  <main>
    <nav class="breadcrumb">
      <a href="/">← back to board</a>
    </nav>

    <article class={`detail status-${data.status}`}>
      <header class="detail-head">
        <div class="detail-status">
          <Flame size={18} class="detail-flame" />
          <span class="status-label">{statusLabels[data.status]}</span>
        </div>
        <h1
          class="title-edit"
          data-card-id={data.id}
          tabindex="0"
          title="Click to edit"
        >{data.title}</h1>

        <dl class="meta-grid">
          <div class="meta-item">
            <dt>Owner</dt>
            <dd><a href={`/people/${data.owner}/`}>🦊 {data.owner}</a></dd>
          </div>
          {data.collaborators.length > 0 && (
            <div class="meta-item">
              <dt>Collaborators</dt>
              <dd>{data.collaborators.map((c, i) => (
                <>
                  <a href={`/people/${c}/`}>{c}</a>{i < data.collaborators.length - 1 ? ', ' : ''}
                </>
              ))}</dd>
            </div>
          )}
          {due && (
            <div class="meta-item">
              <dt>Due</dt>
              <dd>{fmt(due)}</dd>
            </div>
          )}
          {created && (
            <div class="meta-item">
              <dt>Created</dt>
              <dd>{fmt(created)}</dd>
            </div>
          )}
          {completed && (
            <div class="meta-item">
              <dt>Completed</dt>
              <dd>{fmt(completed)}</dd>
            </div>
          )}
          {data.tags.length > 0 && (
            <div class="meta-item">
              <dt>Tags</dt>
              <dd class="tag-list">{data.tags.map((t) => (
                <a href={`/tags/${t}/`} class="tag">#{t}</a>
              ))}</dd>
            </div>
          )}
        </dl>
      </header>

      <section class="detail-body">
        <Content />
      </section>

      <section class="detail-attach" aria-label="Attach an image to this card">
        <label class="attach-button" for={`upload-${data.id}`}>
          <span class="attach-icon" aria-hidden="true">＋</span>
          <span>Attach image</span>
        </label>
        <input
          type="file"
          id={`upload-${data.id}`}
          accept="image/*"
          class="attach-input"
          data-card-id={data.id}
        />
        <span class="attach-status" data-attach-status></span>
      </section>
    </article>
  </main>

  <script>
    // Image upload on the card detail page. Uses the existing
    // POST /api/cards/:id/attachments endpoint with appendToBody=true,
    // so the picture both lands on disk AND appears in the card body
    // without a manual edit step.
    document.addEventListener('change', async (e) => {
      const input = e.target as HTMLInputElement | null;
      if (!input || !input.classList.contains('attach-input')) return;
      const file = input.files?.[0];
      if (!file) return;

      const cardId = input.dataset.cardId;
      if (!cardId) return;

      const status = document.querySelector<HTMLElement>('[data-attach-status]');
      const showStatus = (msg: string, kind: 'idle' | 'work' | 'ok' | 'err' = 'idle') => {
        if (!status) return;
        status.textContent = msg;
        status.dataset.kind = kind;
      };

      showStatus(`Uploading ${file.name}…`, 'work');
      input.disabled = true;

      const fd = new FormData();
      fd.append('file', file);
      fd.append('appendToBody', 'true');

      try {
        const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}/attachments`, {
          method: 'POST',
          body: fd,
        });
        if (!r.ok) {
          const errBody = await r.text();
          throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
        }
        showStatus('Uploaded — refreshing…', 'ok');
        // Reload to render the freshly-appended markdown.
        window.location.reload();
      } catch (err) {
        console.error('upload failed:', err);
        showStatus(err instanceof Error ? err.message : 'upload failed', 'err');
        input.disabled = false;
      }
    });
  </script>

  <script>
    // Click-to-edit title on the card detail page. PATCHes /api/cards/:id
    // with { title } and on success updates the DOM + document.title.
    // Enter commits, Escape cancels. Multi-line input is collapsed to one line.
    const titleEl = document.querySelector<HTMLElement>('h1.title-edit');
    if (titleEl) {
      const cardId = titleEl.dataset.cardId ?? '';
      let original = (titleEl.textContent ?? '').trim();

      const enterEdit = () => {
        if (titleEl.isContentEditable) return;
        original = (titleEl.textContent ?? '').trim();
        titleEl.contentEditable = 'true';
        titleEl.classList.add('editing');
        titleEl.focus();
        const range = document.createRange();
        range.selectNodeContents(titleEl);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      };

      titleEl.addEventListener('click', enterEdit);
      titleEl.addEventListener('keydown', (e) => {
        if (!titleEl.isContentEditable) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            enterEdit();
          }
          return;
        }
        if (e.key === 'Enter') {
          e.preventDefault();
          titleEl.blur();
        } else if (e.key === 'Escape') {
          e.preventDefault();
          titleEl.textContent = original;
          titleEl.blur();
        }
      });

      // Strip rich content from pastes — title is a plain string.
      titleEl.addEventListener('paste', (e) => {
        if (!titleEl.isContentEditable) return;
        e.preventDefault();
        const text = (e.clipboardData?.getData('text') ?? '').replace(/[\r\n\t]+/g, ' ');
        const sel = window.getSelection();
        if (!sel || sel.rangeCount === 0) return;
        const range = sel.getRangeAt(0);
        range.deleteContents();
        const node = document.createTextNode(text);
        range.insertNode(node);
        range.setStartAfter(node);
        range.collapse(true);
        sel.removeAllRanges();
        sel.addRange(range);
      });

      titleEl.addEventListener('blur', async () => {
        if (!titleEl.isContentEditable) return;
        titleEl.contentEditable = 'false';
        titleEl.classList.remove('editing');

        const newTitle = (titleEl.textContent ?? '').replace(/\s+/g, ' ').trim();
        if (newTitle === original) return;
        if (!newTitle) {
          titleEl.textContent = original;
          return;
        }

        titleEl.classList.add('saving');
        try {
          const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: newTitle }),
          });
          if (!r.ok) {
            const errBody = await r.text();
            throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
          }
          titleEl.textContent = newTitle;
          original = newTitle;
          document.title = document.title.replace(/^.*?( — kitsunebi)$/, `${newTitle}$1`);
        } catch (err) {
          console.error('title patch failed:', err);
          titleEl.textContent = original;
          alert(`Couldn't save title: ${err instanceof Error ? err.message : 'unknown error'}`);
        } finally {
          titleEl.classList.remove('saving');
        }
      });
    }
  </script>
</Layout>

<style>
  main {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    margin-bottom: 1.8rem;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.85rem;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .breadcrumb a:hover {
    color: var(--flame-in_progress);
    border-bottom-color: var(--flame-in_progress);
  }

  .detail {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--flame);
    border-radius: 8px;
    padding: 2rem 2.2rem;
    box-shadow: 0 1px 0 var(--flame-glow) inset, 0 0 36px -10px var(--flame-glow);
  }

  .status-backlog { --flame: var(--flame-backlog); --flame-glow: var(--flame-backlog-glow); }
  .status-in_progress { --flame: var(--flame-in_progress); --flame-glow: var(--flame-in_progress-glow); }
  .status-blocked { --flame: var(--flame-blocked); --flame-glow: var(--flame-blocked-glow); }
  .status-done { --flame: var(--flame-done); --flame-glow: var(--flame-done-glow); }
  .status-archived { --flame: var(--flame-archived); --flame-glow: var(--flame-archived-glow); }

  .detail-head {
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 1.2rem;
  }

  .detail-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  :global(.detail-flame) {
    color: var(--flame);
  }

  .status-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--flame);
    font-weight: 600;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 600;
    margin: 0 0 1.2rem 0;
    line-height: 1.1;
    letter-spacing: 0.005em;
  }

  .title-edit {
    cursor: text;
    border-radius: 6px;
    padding: 0.05em 0.25em;
    margin-left: -0.25em;
    transition: background 150ms ease, box-shadow 150ms ease, opacity 150ms ease;
    outline: none;
  }

  .title-edit:hover:not(.editing) {
    background: var(--bg-card-hover);
    box-shadow: 0 0 0 1px var(--border);
  }

  .title-edit:focus-visible:not(.editing) {
    box-shadow: 0 0 0 1px var(--flame);
  }

  .title-edit.editing {
    background: var(--bg-0);
    box-shadow: 0 0 0 1px var(--flame), 0 0 18px -6px var(--flame-glow);
  }

  .title-edit.saving {
    opacity: 0.55;
    pointer-events: none;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.8rem 1.2rem;
    margin: 0;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-item dt {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-soft);
    font-weight: 600;
  }

  .meta-item dd {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-dim);
  }

  .meta-item a {
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 1px dashed var(--border);
    transition: color 150ms ease, border-color 150ms ease;
  }

  .meta-item a:hover {
    color: var(--flame);
    border-bottom-color: var(--flame);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-soft);
    text-decoration: none;
    border-bottom: none !important;
  }

  .tag:hover {
    color: var(--flame) !important;
  }

  .detail-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-dim);
  }

  .detail-body :global(h1),
  .detail-body :global(h2),
  .detail-body :global(h3),
  .detail-body :global(h4) {
    font-family: var(--font-serif);
    color: var(--text);
    margin: 1.6em 0 0.5em;
    font-weight: 600;
    line-height: 1.25;
  }

  .detail-body :global(h2) { font-size: 1.4rem; }
  .detail-body :global(h3) { font-size: 1.15rem; }

  .detail-body :global(p) {
    margin: 0 0 1em;
  }

  .detail-body :global(strong) { color: var(--text); }

  .detail-body :global(ul),
  .detail-body :global(ol) {
    padding-left: 1.4em;
    margin: 0.5em 0 1em;
  }

  .detail-body :global(li) {
    margin-bottom: 0.3em;
  }

  .detail-body :global(input[type="checkbox"]) {
    accent-color: var(--flame);
    margin-right: 0.4em;
  }

  .detail-body :global(img),
  .detail-body :global(video) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1em 0;
    border-radius: 6px;
    border: 1px solid var(--border-soft);
    transition: border-color 180ms ease, box-shadow 220ms ease;
  }

  .detail-body :global(img):hover,
  .detail-body :global(video):hover {
    border-color: var(--flame);
    box-shadow: 0 0 18px -4px var(--flame-glow);
  }

  .detail-body :global(blockquote) {
    border-left: 3px solid var(--flame);
    padding-left: 1em;
    margin: 1em 0;
    color: var(--text);
    font-style: italic;
    opacity: 0.9;
  }

  /* ---------- attach image control ---------- */
  .detail-attach {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 1.6rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-soft);
  }

  .attach-input {
    /* Visually hidden but still in the tab order; the <label> is the
       clickable affordance. */
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .attach-button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.85rem;
    border: 1px dashed var(--border);
    border-radius: 999px;
    color: var(--text-dim);
    font-size: 0.78rem;
    cursor: pointer;
    transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
  }

  .attach-button:hover,
  .attach-input:focus + .attach-button,
  .attach-input:focus-visible ~ .attach-button {
    border-color: var(--flame);
    color: var(--flame);
    background: var(--flame-glow);
  }

  .attach-icon {
    font-size: 1rem;
    line-height: 1;
    color: var(--flame);
  }

  .attach-status {
    font-size: 0.78rem;
    color: var(--text-soft);
    font-variant-numeric: tabular-nums;
  }

  .attach-status[data-kind="work"] { color: var(--flame-in_progress); }
  .attach-status[data-kind="ok"]   { color: var(--flame-done); }
  .attach-status[data-kind="err"]  { color: var(--flame-blocked); }
</style>
