---
import { getEntry, render } from 'astro:content';
import { marked } from 'marked';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import Layout from '../../layouts/Layout.astro';
import Flame from '../../components/Flame.astro';
import { listComments } from '../../lib/comments-fs';
import { readCard } from '../../lib/cards-fs';

// Server-rendered. We try Astro's content collection first ~ that path
// gives us schema validation + the full Astro <Content /> component with
// its remark/rehype plugins. But the collection is bundled at BUILD time,
// so cards created via the API after the last deploy aren't in it yet.
// Fall back to reading the card directly off disk and rendering its body
// with `marked` so newly-created cards work immediately. Schema goodness
// is lost on the fallback path; correctness is gained.
const { id } = Astro.params;
if (!id) {
  return new Response('Not Found', { status: 404 });
}

let data: Record<string, any>;
let Content: AstroComponentFactory | null = null;
let bodyHtml: string | null = null;

const card = await getEntry('cards', id);
if (card) {
  const rendered = await render(card);
  Content = rendered.Content;
  data = card.data;
} else {
  // Bundle miss ~ try disk before giving up.
  let disk;
  try {
    disk = await readCard(id);
  } catch (err: any) {
    if (err?.code === 'ENOENT') {
      return new Response('Not Found', { status: 404 });
    }
    throw err;
  }
  // Normalize frontmatter to the same shape the schema-validated path
  // exposes (sensible defaults so the template doesn't choke on missing
  // optional fields).
  const fm = disk.frontmatter as Record<string, any>;
  data = {
    id: fm.id ?? id,
    title: fm.title ?? id,
    status: fm.status ?? 'backlog',
    owner: fm.owner ?? '',
    collaborators: Array.isArray(fm.collaborators) ? fm.collaborators : [],
    tags: Array.isArray(fm.tags) ? fm.tags : [],
    blocked_by: Array.isArray(fm.blocked_by) ? fm.blocked_by : [],
    due: fm.due ?? null,
    created: fm.created ?? null,
    completed: fm.completed ?? null,
    order: fm.order ?? null,
  };
  bodyHtml = await marked.parse(disk.body ?? '', { async: true });
}

const comments = await listComments(data.id);

const statusLabels: Record<string, string> = {
  backlog: 'Backlog',
  blocked: 'Blocked',
  in_progress: 'In Progress',
  done: 'Done',
  archived: 'Archived',
};

const due = data.due ? new Date(data.due) : null;
const created = data.created ? new Date(data.created) : null;
const completed = data.completed ? new Date(data.completed) : null;

const fmt = (d: Date | null) =>
  d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : null;

/** Friendly comment timestamp: "Apr 26, 8:12 PM" if same year, else with year. */
const fmtCommentTime = (iso: string): string => {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const sameYear = d.getFullYear() === new Date().getFullYear();
  return d.toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    year: sameYear ? undefined : 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    hour12: true,
  });
};
---

<Layout title={`${data.title} — kitsunebi`} description={`${statusLabels[data.status]} · owned by ${data.owner}`}>
  <main>
    <nav class="breadcrumb">
      <a href="/">← back to board</a>
    </nav>

    <article class={`detail status-${data.status}`}>
      <header class="detail-head">
        <div class="detail-status">
          <Flame size={18} class="detail-flame" />
          <span class="status-label">{statusLabels[data.status]}</span>
        </div>
        <h1
          class="title-edit"
          data-card-id={data.id}
          tabindex="0"
          title="Click to edit"
        >{data.title}</h1>

        <dl class="meta-grid">
          <div class="meta-item">
            <dt>Owner</dt>
            <dd class="owner-chip" data-card-id={data.id} data-owner={data.owner}>
              <a href={`/people/${data.owner}/`} class="owner-link">🦊 {data.owner}</a>
              <button class="owner-edit" type="button" aria-label="Edit owner">✎</button>
            </dd>
          </div>
          {data.collaborators.length > 0 && (
            <div class="meta-item">
              <dt>Collaborators</dt>
              <dd>{data.collaborators.map((c, i) => (
                <>
                  <a href={`/people/${c}/`}>{c}</a>{i < data.collaborators.length - 1 ? ', ' : ''}
                </>
              ))}</dd>
            </div>
          )}
          {due && (
            <div class="meta-item">
              <dt>Due</dt>
              <dd>{fmt(due)}</dd>
            </div>
          )}
          {created && (
            <div class="meta-item">
              <dt>Created</dt>
              <dd>{fmt(created)}</dd>
            </div>
          )}
          {completed && (
            <div class="meta-item">
              <dt>Completed</dt>
              <dd>{fmt(completed)}</dd>
            </div>
          )}
          <div class="meta-item">
            <dt>Tags</dt>
            <dd class="tag-list" data-card-id={data.id}>
              {data.tags.map((t) => (
                <span class="tag-chip" data-tag={t}>
                  <a href={`/tags/${t}/`} class="tag">#{t}</a>
                  <button class="tag-remove" type="button" aria-label={`Remove tag ${t}`}>✕</button>
                </span>
              ))}
              <button class="tag-add" type="button" aria-label="Add a tag">+ tag</button>
            </dd>
          </div>
        </dl>
      </header>

      <section class="detail-body" data-card-id={data.id}>
        {Content ? <Content /> : <Fragment set:html={bodyHtml ?? ''} />}
      </section>

      <section id="comments" class="comments" aria-label="Comments" data-card-id={data.id}>
        <header class="comments-head">
          <h2>Comments</h2>
          <span class="comments-count">{comments.length === 0 ? 'none yet' : `${comments.length}`}</span>
        </header>

        <ol class="comment-list" data-comment-list>
          {comments.map((c) => (
            <li class="comment" data-comment-id={c.id}>
              <header class="comment-meta">
                <a href={`/people/${c.author}/`} class="comment-author">🦊 {c.author}</a>
                <time class="comment-time" datetime={c.createdAt}>{fmtCommentTime(c.createdAt)}</time>
              </header>
              <div class="comment-body">{c.text}</div>
            </li>
          ))}
        </ol>

        <form class="comment-form" data-comment-form>
          <textarea
            name="text"
            placeholder="Leave a comment…"
            rows="3"
            required
            maxlength="4000"
          ></textarea>
          <div class="comment-form-row">
            <label class="comment-author-field">
              as <input type="text" name="author" placeholder="your name" maxlength="60" data-comment-author-input />
            </label>
            <button type="submit">Post</button>
            <span class="comment-form-status" data-comment-status></span>
          </div>
        </form>
      </section>

      <section class="detail-attach" aria-label="Attach an image to this card">
        <label class="attach-button" for={`upload-${data.id}`}>
          <span class="attach-icon" aria-hidden="true">＋</span>
          <span>Attach image</span>
        </label>
        <input
          type="file"
          id={`upload-${data.id}`}
          accept="image/*"
          class="attach-input"
          data-card-id={data.id}
        />
        <span class="attach-status" data-attach-status></span>
      </section>
    </article>
  </main>

  <script>
    // Image upload on the card detail page. Uses the existing
    // POST /api/cards/:id/attachments endpoint with appendToBody=true,
    // so the picture both lands on disk AND appears in the card body
    // without a manual edit step.
    document.addEventListener('change', async (e) => {
      const input = e.target as HTMLInputElement | null;
      if (!input || !input.classList.contains('attach-input')) return;
      const file = input.files?.[0];
      if (!file) return;

      const cardId = input.dataset.cardId;
      if (!cardId) return;

      const status = document.querySelector<HTMLElement>('[data-attach-status]');
      const showStatus = (msg: string, kind: 'idle' | 'work' | 'ok' | 'err' = 'idle') => {
        if (!status) return;
        status.textContent = msg;
        status.dataset.kind = kind;
      };

      showStatus(`Uploading ${file.name}…`, 'work');
      input.disabled = true;

      const fd = new FormData();
      fd.append('file', file);
      fd.append('appendToBody', 'true');

      try {
        const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}/attachments`, {
          method: 'POST',
          body: fd,
        });
        if (!r.ok) {
          const errBody = await r.text();
          throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
        }
        showStatus('Uploaded — refreshing…', 'ok');
        // Reload to render the freshly-appended markdown.
        window.location.reload();
      } catch (err) {
        console.error('upload failed:', err);
        showStatus(err instanceof Error ? err.message : 'upload failed', 'err');
        input.disabled = false;
      }
    });
  </script>

  <script>
    // Click-to-edit title on the card detail page. PATCHes /api/cards/:id
    // with { title } and on success updates the DOM + document.title.
    // Enter commits, Escape cancels. Multi-line input is collapsed to one line.
    const titleEl = document.querySelector<HTMLElement>('h1.title-edit');
    if (titleEl) {
      const cardId = titleEl.dataset.cardId ?? '';
      let original = (titleEl.textContent ?? '').trim();

      const enterEdit = () => {
        if (titleEl.isContentEditable) return;
        original = (titleEl.textContent ?? '').trim();
        titleEl.contentEditable = 'true';
        titleEl.classList.add('editing');
        titleEl.focus();
        const range = document.createRange();
        range.selectNodeContents(titleEl);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      };

      titleEl.addEventListener('click', enterEdit);
      titleEl.addEventListener('keydown', (e) => {
        if (!titleEl.isContentEditable) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            enterEdit();
          }
          return;
        }
        if (e.key === 'Enter') {
          e.preventDefault();
          titleEl.blur();
        } else if (e.key === 'Escape') {
          e.preventDefault();
          titleEl.textContent = original;
          titleEl.blur();
        }
      });

      // Strip rich content from pastes — title is a plain string.
      titleEl.addEventListener('paste', (e) => {
        if (!titleEl.isContentEditable) return;
        e.preventDefault();
        const text = (e.clipboardData?.getData('text') ?? '').replace(/[\r\n\t]+/g, ' ');
        const sel = window.getSelection();
        if (!sel || sel.rangeCount === 0) return;
        const range = sel.getRangeAt(0);
        range.deleteContents();
        const node = document.createTextNode(text);
        range.insertNode(node);
        range.setStartAfter(node);
        range.collapse(true);
        sel.removeAllRanges();
        sel.addRange(range);
      });

      titleEl.addEventListener('blur', async () => {
        if (!titleEl.isContentEditable) return;
        titleEl.contentEditable = 'false';
        titleEl.classList.remove('editing');

        const newTitle = (titleEl.textContent ?? '').replace(/\s+/g, ' ').trim();
        if (newTitle === original) return;
        if (!newTitle) {
          titleEl.textContent = original;
          return;
        }

        titleEl.classList.add('saving');
        try {
          const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: newTitle }),
          });
          if (!r.ok) {
            const errBody = await r.text();
            throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
          }
          titleEl.textContent = newTitle;
          original = newTitle;
          document.title = document.title.replace(/^.*?( — kitsunebi)$/, `${newTitle}$1`);
        } catch (err) {
          console.error('title patch failed:', err);
          titleEl.textContent = original;
          alert(`Couldn't save title: ${err instanceof Error ? err.message : 'unknown error'}`);
        } finally {
          titleEl.classList.remove('saving');
        }
      });
    }
  </script>

  <script>
    // Inline-edit tags: click ✕ on a chip to remove, "+ tag" to add a new one.
    // Each change PATCHes /api/cards/:id with the full updated tags array.
    const tagListEl = document.querySelector<HTMLElement>('dd.tag-list');
    if (tagListEl) {
      const cardId = tagListEl.dataset.cardId ?? '';

      const currentTags = (): string[] =>
        [...tagListEl.querySelectorAll<HTMLElement>('.tag-chip')]
          .map((c) => c.dataset.tag ?? '')
          .filter(Boolean);

      const patchTags = async (next: string[]): Promise<boolean> => {
        try {
          const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tags: next }),
          });
          if (!r.ok) {
            const errBody = await r.text();
            throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
          }
          return true;
        } catch (err) {
          console.error('tag patch failed:', err);
          alert(`Couldn't save tags: ${err instanceof Error ? err.message : 'unknown error'}`);
          return false;
        }
      };

      const makeChip = (tag: string): HTMLElement => {
        const span = document.createElement('span');
        span.className = 'tag-chip';
        span.dataset.tag = tag;

        const a = document.createElement('a');
        a.href = `/tags/${encodeURIComponent(tag)}/`;
        a.className = 'tag';
        a.textContent = `#${tag}`;
        span.appendChild(a);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'tag-remove';
        btn.setAttribute('aria-label', `Remove tag ${tag}`);
        btn.textContent = '✕';
        span.appendChild(btn);

        return span;
      };

      // Remove (event-delegated so dynamically-added chips work too).
      tagListEl.addEventListener('click', async (e) => {
        const removeBtn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tag-remove');
        if (!removeBtn) return;
        e.preventDefault();
        const chip = removeBtn.closest<HTMLElement>('.tag-chip');
        const tag = chip?.dataset.tag;
        if (!chip || !tag) return;

        const next = currentTags().filter((t) => t !== tag);
        chip.classList.add('saving');
        const ok = await patchTags(next);
        if (ok) {
          chip.remove();
        } else {
          chip.classList.remove('saving');
        }
      });

      // Add. Click "+ tag" → swap to input → Enter/blur commits, Escape cancels.
      const addBtn = tagListEl.querySelector<HTMLButtonElement>('.tag-add');
      if (addBtn) {
        addBtn.addEventListener('click', () => {
          if (tagListEl.querySelector('.tag-input')) return;

          const input = document.createElement('input');
          input.type = 'text';
          input.className = 'tag-input';
          input.placeholder = 'tag-name';
          input.maxLength = 60;
          addBtn.style.display = 'none';
          tagListEl.appendChild(input);
          input.focus();

          const cleanup = (cancelled: boolean) => {
            const value = input.value.trim();
            input.remove();
            addBtn.style.display = '';
            if (cancelled || !value) return;
            const existing = currentTags();
            if (existing.includes(value)) return;
            const next = [...existing, value];
            patchTags(next).then((ok) => {
              if (ok) tagListEl.insertBefore(makeChip(value), addBtn);
            });
          };

          let dispatched = false;
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
              e.preventDefault();
              dispatched = true;
              cleanup(false);
            } else if (e.key === 'Escape') {
              e.preventDefault();
              dispatched = true;
              cleanup(true);
            }
          });
          input.addEventListener('blur', () => {
            if (dispatched) return;
            cleanup(false);
          });
        });
      }
    }
  </script>

  <script>
    // Inline-edit owner: click ✎ on hover to swap the owner link for an
    // input. Enter / blur commits, Escape cancels. PATCHes /api/cards/:id
    // with { owner } and on success updates the link text + href.
    const ownerChip = document.querySelector<HTMLElement>('dd.owner-chip');
    if (ownerChip) {
      const cardId = ownerChip.dataset.cardId ?? '';
      const ownerLink = ownerChip.querySelector<HTMLAnchorElement>('.owner-link');
      const editBtn = ownerChip.querySelector<HTMLButtonElement>('.owner-edit');

      const enterEdit = () => {
        if (ownerChip.classList.contains('is-editing') || !ownerLink) return;
        const current = ownerChip.dataset.owner ?? '';
        ownerChip.classList.add('is-editing');

        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'owner-input';
        input.value = current;
        input.maxLength = 60;

        let dispatched = false;
        const finish = async (cancelled: boolean) => {
          if (dispatched) return;
          dispatched = true;
          const next = input.value.trim();
          input.remove();
          ownerChip.classList.remove('is-editing');

          if (cancelled || !next || next === current) return;

          ownerChip.classList.add('saving');
          try {
            const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ owner: next }),
            });
            if (!r.ok) {
              const errBody = await r.text();
              throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
            }
            ownerLink.textContent = `🦊 ${next}`;
            ownerLink.href = `/people/${encodeURIComponent(next)}/`;
            ownerChip.dataset.owner = next;
          } catch (err) {
            console.error('owner patch failed:', err);
            alert(`Couldn't save owner: ${err instanceof Error ? err.message : 'unknown error'}`);
          } finally {
            ownerChip.classList.remove('saving');
          }
        };

        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            finish(false);
          } else if (e.key === 'Escape') {
            e.preventDefault();
            finish(true);
          }
        });
        input.addEventListener('blur', () => finish(false));

        ownerChip.appendChild(input);
        input.focus();
        input.select();
      };

      editBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        enterEdit();
      });
    }
  </script>

  <script>
    // Comment form: POST /api/cards/:id/comments, then reload so the new
    // comment lands via SSR with the same scoped CSS + formatted timestamp
    // as the existing ones. Mirrors the attach-image upload pattern.
    //
    // Persists the author name in localStorage so once a user types it
    // (or pastes their agent name), it sticks across page loads.
    const AUTHOR_KEY = 'kitsunebi:comment-author';
    const commentSection = document.querySelector<HTMLElement>('section.comments');
    if (commentSection) {
      const cardId = commentSection.dataset.cardId ?? '';
      const form = commentSection.querySelector<HTMLFormElement>('[data-comment-form]');
      const status = commentSection.querySelector<HTMLElement>('[data-comment-status]');
      const authorInput = commentSection.querySelector<HTMLInputElement>('[data-comment-author-input]');

      // Pre-fill the author field from the last successful post.
      if (authorInput) {
        try {
          const saved = window.localStorage.getItem(AUTHOR_KEY) ?? '';
          if (saved) authorInput.value = saved;
        } catch {
          // localStorage can throw in private mode / sandboxed contexts; non-fatal.
        }
      }

      const showStatus = (msg: string, kind: 'work' | 'ok' | 'err' | 'idle' = 'idle') => {
        if (!status) return;
        status.textContent = msg;
        status.dataset.kind = kind;
      };

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const text = String(fd.get('text') ?? '').trim();
        const author = String(fd.get('author') ?? '').trim();
        if (!text) return;

        showStatus('Posting…', 'work');
        const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;

        try {
          const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}/comments`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text, author: author || undefined }),
          });
          if (!r.ok) {
            const errBody = await r.text();
            throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
          }
          if (author) {
            try { window.localStorage.setItem(AUTHOR_KEY, author); } catch { /* non-fatal */ }
          }
          showStatus('Posted — refreshing…', 'ok');
          window.location.reload();
        } catch (err) {
          console.error('comment post failed:', err);
          showStatus(err instanceof Error ? err.message : 'post failed', 'err');
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }
  </script>

  <script>
    // Detail-page image thumbnails: wrap each <img>/<video> in `.detail-body`
    // with `<span class="thumb"><a class="thumb-link" target="_blank">…</a>
    // <button class="thumb-remove">✕</button></span>` so they render as
    // 80×80 chips (per the CSS), open full-size on click, and surface a
    // hover ✕ that calls DELETE /api/cards/:id/attachments?file=<basename>.
    // Mirror of the board's wrapThumbnails() in index.astro at a different
    // size; reuses the same DELETE endpoint shipped with PR #7.
    const detailBody = document.querySelector<HTMLElement>('.detail-body');
    if (detailBody) {
      const cardId = detailBody.dataset.cardId ?? '';
      detailBody.querySelectorAll<HTMLElement>('img, video').forEach((el) => {
        // Skip if already wrapped (re-runs are no-ops).
        const parent = el.parentElement;
        if (parent?.classList.contains('thumb-link') || parent?.classList.contains('thumb')) return;

        const src = (el as HTMLImageElement | HTMLVideoElement).getAttribute('src') ?? '';
        const expectedPrefix = `/attachments/${cardId}/`;

        const wrap = document.createElement('span');
        wrap.className = 'thumb';

        // Anchor wrapping for click-to-zoom: opens full-size in a new tab.
        const link = document.createElement('a');
        link.href = src;
        link.target = '_blank';
        link.rel = 'noopener';
        link.className = 'thumb-link';

        el.replaceWith(wrap);
        link.appendChild(el);
        wrap.appendChild(link);

        // Only wire the ✕ for files we actually own (under our attachments
        // namespace). Markdown-linked images from other origins still get
        // wrapped for layout consistency, just without the delete button.
        if (!cardId || !src.startsWith(expectedPrefix)) return;
        const filename = decodeURIComponent(src.slice(expectedPrefix.length));

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'thumb-remove';
        btn.setAttribute('aria-label', `Remove ${filename}`);
        btn.title = `Remove ${filename}`;
        btn.textContent = '✕';
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (!window.confirm(`Remove ${filename}?`)) return;
          btn.disabled = true;
          try {
            const r = await fetch(
              `/api/cards/${encodeURIComponent(cardId)}/attachments?file=${encodeURIComponent(filename)}`,
              { method: 'DELETE' },
            );
            if (!r.ok) {
              const errBody = await r.text();
              throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
            }
            wrap.remove();
          } catch (err) {
            console.error('attachment delete failed:', err);
            alert(`Couldn't remove image: ${err instanceof Error ? err.message : 'unknown error'}`);
            btn.disabled = false;
          }
        });
        wrap.appendChild(btn);
      });
    }
  </script>
</Layout>

<style>
  main {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    margin-bottom: 1.8rem;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.85rem;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

