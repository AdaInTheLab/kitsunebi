---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Flame from '../../components/Flame.astro';

export async function getStaticPaths() {
  const cards = await getCollection('cards');
  return cards.map((card) => ({
    params: { id: card.id },
    props: { card },
  }));
}

const { card } = Astro.props;
const { Content } = await render(card);
const data = card.data;

const statusLabels: Record<string, string> = {
  backlog: 'Backlog',
  blocked: 'Blocked',
  in_progress: 'In Progress',
  done: 'Done',
  archived: 'Archived',
};

const due = data.due ? new Date(data.due) : null;
const created = data.created ? new Date(data.created) : null;
const completed = data.completed ? new Date(data.completed) : null;

const fmt = (d: Date | null) =>
  d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
---

<Layout title={`${data.title} — kitsunebi`} description={`${statusLabels[data.status]} · owned by ${data.owner}`}>
  <main>
    <nav class="breadcrumb">
      <a href="/">← back to board</a>
    </nav>

    <article class={`detail status-${data.status}`}>
      <header class="detail-head">
        <div class="detail-status">
          <Flame size={18} class="detail-flame" />
          <span class="status-label">{statusLabels[data.status]}</span>
        </div>
        <h1>{data.title}</h1>

        <dl class="meta-grid">
          <div class="meta-item">
            <dt>Owner</dt>
            <dd><a href={`/people/${data.owner}/`}>🦊 {data.owner}</a></dd>
          </div>
          {data.collaborators.length > 0 && (
            <div class="meta-item">
              <dt>Collaborators</dt>
              <dd>{data.collaborators.map((c, i) => (
                <>
                  <a href={`/people/${c}/`}>{c}</a>{i < data.collaborators.length - 1 ? ', ' : ''}
                </>
              ))}</dd>
            </div>
          )}
          {due && (
            <div class="meta-item">
              <dt>Due</dt>
              <dd>{fmt(due)}</dd>
            </div>
          )}
          {created && (
            <div class="meta-item">
              <dt>Created</dt>
              <dd>{fmt(created)}</dd>
            </div>
          )}
          {completed && (
            <div class="meta-item">
              <dt>Completed</dt>
              <dd>{fmt(completed)}</dd>
            </div>
          )}
          {data.tags.length > 0 && (
            <div class="meta-item">
              <dt>Tags</dt>
              <dd class="tag-list">{data.tags.map((t) => (
                <a href={`/tags/${t}/`} class="tag">#{t}</a>
              ))}</dd>
            </div>
          )}
        </dl>
      </header>

      <section class="detail-body">
        <Content />
      </section>
    </article>
  </main>
</Layout>

<style>
  main {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    margin-bottom: 1.8rem;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.85rem;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .breadcrumb a:hover {
    color: var(--flame-in_progress);
    border-bottom-color: var(--flame-in_progress);
  }

  .detail {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 4px solid var(--flame);
    border-radius: 8px;
    padding: 2rem 2.2rem;
    box-shadow: 0 1px 0 var(--flame-glow) inset, 0 0 36px -10px var(--flame-glow);
  }

  .status-backlog { --flame: var(--flame-backlog); --flame-glow: var(--flame-backlog-glow); }
  .status-in_progress { --flame: var(--flame-in_progress); --flame-glow: var(--flame-in_progress-glow); }
  .status-blocked { --flame: var(--flame-blocked); --flame-glow: var(--flame-blocked-glow); }
  .status-done { --flame: var(--flame-done); --flame-glow: var(--flame-done-glow); }
  .status-archived { --flame: var(--flame-archived); --flame-glow: var(--flame-archived-glow); }

  .detail-head {
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 1.2rem;
  }

  .detail-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  :global(.detail-flame) {
    color: var(--flame);
  }

  .status-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--flame);
    font-weight: 600;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 600;
    margin: 0 0 1.2rem 0;
    line-height: 1.1;
    letter-spacing: 0.005em;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.8rem 1.2rem;
    margin: 0;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-item dt {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-soft);
    font-weight: 600;
  }

  .meta-item dd {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-dim);
  }

  .meta-item a {
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 1px dashed var(--border);
    transition: color 150ms ease, border-color 150ms ease;
  }

  .meta-item a:hover {
    color: var(--flame);
    border-bottom-color: var(--flame);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-soft);
    text-decoration: none;
    border-bottom: none !important;
  }

  .tag:hover {
    color: var(--flame) !important;
  }

  .detail-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-dim);
  }

  .detail-body :global(h1),
  .detail-body :global(h2),
  .detail-body :global(h3),
  .detail-body :global(h4) {
    font-family: var(--font-serif);
    color: var(--text);
    margin: 1.6em 0 0.5em;
    font-weight: 600;
    line-height: 1.25;
  }

  .detail-body :global(h2) { font-size: 1.4rem; }
  .detail-body :global(h3) { font-size: 1.15rem; }

  .detail-body :global(p) {
    margin: 0 0 1em;
  }

  .detail-body :global(strong) { color: var(--text); }

  .detail-body :global(ul),
  .detail-body :global(ol) {
    padding-left: 1.4em;
    margin: 0.5em 0 1em;
  }

  .detail-body :global(li) {
    margin-bottom: 0.3em;
  }

  .detail-body :global(input[type="checkbox"]) {
    accent-color: var(--flame);
    margin-right: 0.4em;
  }

  .detail-body :global(img),
  .detail-body :global(video) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1em 0;
    border-radius: 6px;
    border: 1px solid var(--border-soft);
    transition: border-color 180ms ease, box-shadow 220ms ease;
  }

  .detail-body :global(img):hover,
  .detail-body :global(video):hover {
    border-color: var(--flame);
    box-shadow: 0 0 18px -4px var(--flame-glow);
  }

  .detail-body :global(blockquote) {
    border-left: 3px solid var(--flame);
    padding-left: 1em;
    margin: 1em 0;
    color: var(--text);
    font-style: italic;
    opacity: 0.9;
  }
</style>
