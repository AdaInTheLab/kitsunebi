---
import type { CollectionEntry } from 'astro:content';
import Card from './Card.astro';
import Flame from './Flame.astro';

interface Props {
  status: 'backlog' | 'in_progress' | 'blocked' | 'done' | 'archived';
  label: string;
  cards: CollectionEntry<'cards'>[];
  /** Map of card id → comment count. Cards not in the map render with no badge. */
  commentCounts?: Map<string, number>;
}

const { status, label, cards, commentCounts } = Astro.props;
---

<section class={`column status-${status}`} data-column={status}>
  <header class="column-head">
    <button class="column-toggle" type="button" aria-label={`Collapse ${label}`} data-toggle={status}>
      <Flame size={14} class="col-flame" />
      <h2>{label}</h2>
      <span class="count">{cards.length}</span>
      <span class="chevron" aria-hidden="true">▾</span>
    </button>
  </header>

  <div class="column-body">
    {cards.length === 0 ? (
      <div class="empty">— quiet —</div>
    ) : (
      cards.map((card, i) => <Card card={card} index={i} commentCount={commentCounts?.get(card.id) ?? 0} />)
    )}
  </div>
</section>

<script>
  // Column collapse state — persisted per column in localStorage
  const STORAGE_KEY = 'kitsunebi:collapsed-columns';

  function getCollapsed(): Set<string> {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return new Set(raw ? JSON.parse(raw) : []);
    } catch {
      return new Set();
    }
  }

  function saveCollapsed(set: Set<string>) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...set]));
    } catch {}
  }

  function applyCollapsed() {
    const collapsed = getCollapsed();
    document.querySelectorAll<HTMLElement>('[data-column]').forEach((col) => {
      const key = col.dataset.column!;
      col.classList.toggle('is-collapsed', collapsed.has(key));
    });
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-toggle]');
    if (!btn) return;
    const key = btn.dataset.toggle!;
    const collapsed = getCollapsed();
    if (collapsed.has(key)) collapsed.delete(key);
    else collapsed.add(key);
    saveCollapsed(collapsed);
    applyCollapsed();
  });

  applyCollapsed();
</script>

<style>
  .column {
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .status-backlog { --flame: var(--flame-backlog); --flame-glow: var(--flame-backlog-glow); }
  .status-in_progress { --flame: var(--flame-in_progress); --flame-glow: var(--flame-in_progress-glow); }
  .status-blocked { --flame: var(--flame-blocked); --flame-glow: var(--flame-blocked-glow); }
  .status-done { --flame: var(--flame-done); --flame-glow: var(--flame-done-glow); }
  .status-archived { --flame: var(--flame-archived); --flame-glow: var(--flame-archived-glow); }

  .column-head {
    padding: 0.5rem 0 0.85rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.9rem;
    position: sticky;
    top: 0;
    background: linear-gradient(180deg, rgba(10,10,14,0.92) 85%, transparent);
    backdrop-filter: blur(6px);
    z-index: 1;
  }

  .column-toggle {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    padding: 0 0.25rem;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    text-align: left;
    font: inherit;
  }

  .chevron {
    margin-left: auto;
    color: var(--text-soft);
    font-size: 0.7rem;
    transition: transform 180ms ease, color 180ms ease;
  }

  .column-toggle:hover .chevron {
    color: var(--flame);
  }

  .is-collapsed .chevron {
    transform: rotate(-90deg);
  }

  .is-collapsed .column-body {
    display: none;
  }

  .column :global(.col-flame) {
    color: var(--flame);
  }

  .column-head h2 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    flex: 1;
  }

  .count {
    font-size: 0.78rem;
    color: var(--text-soft);
    font-variant-numeric: tabular-nums;
    padding: 0.1rem 0.5rem;
    border: 1px solid var(--border-soft);
    border-radius: 999px;
  }

  .empty {
    font-size: 0.8rem;
    color: var(--text-soft);
    text-align: center;
    padding: 1.5rem 0.5rem;
    font-style: italic;
  }
</style>
