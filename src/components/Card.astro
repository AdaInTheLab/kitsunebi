---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  card: CollectionEntry<'cards'>;
  index?: number;
}

const { card, index = 0 } = Astro.props;
const { Content } = await render(card);
const data = card.data;

const due = data.due ? new Date(data.due) : null;
const now = new Date();
const daysUntilDue = due ? Math.ceil((due.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)) : null;
const dueClass = daysUntilDue === null
  ? ''
  : daysUntilDue < 0
    ? 'overdue'
    : daysUntilDue <= 3
      ? 'urgent'
      : daysUntilDue <= 7
        ? 'soon'
        : '';
---

<article
  class={`card status-${data.status}`}
  style={`--card-index: ${index};`}
  data-owner={data.owner}
  data-collaborators={data.collaborators.join(',')}
  data-tags={data.tags.join(',')}
  data-card-id={data.id}
  data-status={data.status}
  data-order={typeof data.order === 'number' ? String(data.order) : ''}
  data-created={data.created ?? ''}
  draggable="true"
>
  <header class="card-head">
    <h3 class="card-title">
      <a href={`/cards/${data.id}/`}>{data.title}</a>
    </h3>
    <div class="card-meta">
      <span class="owner">🦊 {data.owner}</span>
      {due && (
        <span class={`due ${dueClass}`} title={data.due ?? undefined}>
          {due.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
        </span>
      )}
    </div>
  </header>

  {data.collaborators.length > 0 && (
    <div class="collaborators">
      {data.collaborators.map((c) => <span class="chip">{c}</span>)}
    </div>
  )}

  <div class="card-body">
    <Content />
  </div>

  {data.tags.length > 0 && (
    <footer class="card-foot">
      {data.tags.map((t) => <a href={`/tags/${t}/`} class="tag">#{t}</a>)}
    </footer>
  )}
</article>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--flame);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    margin-bottom: 0.75rem;
    box-shadow: 0 1px 0 var(--flame-glow) inset, 0 0 18px -8px var(--flame-glow);
    transition: transform 120ms ease, box-shadow 180ms ease, background 160ms ease;
    animation: cardIgnite 600ms cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: calc(var(--card-index, 0) * 45ms);
  }

  @keyframes cardIgnite {
    0%   { opacity: 0; transform: translateY(6px); filter: blur(2px); }
    60%  { opacity: 0.9; filter: blur(0); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .card { animation: none; }
  }

  .card:hover,
  .card.kbd-focus {
    background: var(--bg-card-hover);
    transform: translateY(-1px);
    box-shadow: 0 2px 0 var(--flame-glow) inset, 0 0 22px -6px var(--flame-glow);
  }

  .card.kbd-focus {
    outline: 1px solid var(--flame);
    outline-offset: 1px;
  }

  /* Drag-and-drop affordances. Cards are draggable from anywhere; we use
     `cursor: grab` on hover so it's discoverable, and `grabbing` while held. */
  .card { cursor: grab; }
  .card:active { cursor: grabbing; }

  .card.is-dragging {
    opacity: 0.45;
    transform: scale(0.98) translateY(-1px);
  }

  /* Don't let inner links/buttons override the grab cursor — but DO let
     them remain clickable. The drag listener stops short of them. */
  .card a, .card button {
    cursor: pointer;
  }

  .status-backlog { --flame: var(--flame-backlog); --flame-glow: var(--flame-backlog-glow); }
  .status-in_progress { --flame: var(--flame-in_progress); --flame-glow: var(--flame-in_progress-glow); }
  .status-blocked { --flame: var(--flame-blocked); --flame-glow: var(--flame-blocked-glow); }
  .status-done { --flame: var(--flame-done); --flame-glow: var(--flame-done-glow); }
  .status-archived { --flame: var(--flame-archived); --flame-glow: var(--flame-archived-glow); opacity: 0.55; }

  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.005em;
    flex: 1;
  }

  .card-title a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .card-title a:hover {
    color: var(--flame);
    border-bottom-color: var(--flame);
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-end;
    font-size: 0.75rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .owner {
    color: var(--text-dim);
  }

  .due {
    color: var(--text-soft);
    font-variant-numeric: tabular-nums;
  }

  .due.soon { color: var(--flame-done); }

  .due.urgent {
    color: var(--flame-in_progress);
    font-weight: 600;
    text-shadow: 0 0 8px var(--flame-in_progress-glow);
    animation: urgentPulse 2.4s ease-in-out infinite;
  }

  .due.overdue {
    color: var(--flame-blocked);
    font-weight: 700;
    text-shadow: 0 0 10px var(--flame-blocked-glow);
    animation: overduePulse 1.6s ease-in-out infinite;
  }

  @keyframes urgentPulse {
    0%, 100% { opacity: 0.85; text-shadow: 0 0 8px var(--flame-in_progress-glow); }
    50%      { opacity: 1;    text-shadow: 0 0 14px var(--flame-in_progress); }
  }

  @keyframes overduePulse {
    0%, 100% { opacity: 0.85; text-shadow: 0 0 10px var(--flame-blocked-glow); }
    50%      { opacity: 1;    text-shadow: 0 0 18px var(--flame-blocked); }
  }

  @media (prefers-reduced-motion: reduce) {
    .due.urgent, .due.overdue { animation: none; }
  }

  .collaborators {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.6rem;
  }

  .chip {
    background: var(--bg-0);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.08rem 0.55rem;
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .card-body {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.55;
  }

  .card-body :global(p) {
    margin: 0 0 0.6em 0;
  }

  .card-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .card-body :global(ul) {
    padding-left: 1.1em;
    margin: 0.4em 0;
  }

  .card-body :global(li) {
    margin-bottom: 0.15em;
  }

  .card-body :global(input[type="checkbox"]) {
    accent-color: var(--flame);
    margin-right: 0.35em;
  }

  .card-body :global(h1),
  .card-body :global(h2),
  .card-body :global(h3),
  .card-body :global(h4) {
    font-size: 0.85rem;
    margin: 0.9em 0 0.3em 0;
    color: var(--text);
    font-weight: 600;
  }

  .card-body :global(strong) {
    color: var(--text);
  }

  /* On the board, attached images render as 50×50 1:1 thumbnails instead of
     full-width. Multiple thumbs flow inline-block and wrap. The full image
     is still viewable on the card detail page. */
  .card-body :global(.thumb) {
    position: relative;
    display: inline-block;
    margin: 0.4em 0.3em 0.4em 0;
    vertical-align: top;
  }

  .card-body :global(.thumb img),
  .card-body :global(.thumb video) {
    display: block;
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border-soft);
    transition: border-color 180ms ease, box-shadow 220ms ease;
  }

  .card:hover .card-body :global(.thumb img),
  .card:hover .card-body :global(.thumb video) {
    border-color: var(--flame);
    box-shadow: 0 0 14px -4px var(--flame-glow);
  }

  .card-body :global(.thumb-remove) {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 16px;
    height: 16px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.72);
    color: #fff;
    font-size: 11px;
    line-height: 14px;
    text-align: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 150ms ease, background 150ms ease;
  }

  .card-body :global(.thumb:hover .thumb-remove),
  .card-body :global(.thumb-remove:focus-visible) {
    opacity: 1;
  }

  .card-body :global(.thumb-remove:hover),
  .card-body :global(.thumb-remove:focus-visible) {
    background: var(--flame-blocked);
  }

  .card-body :global(figure) {
    margin: 0.6em 0;
  }

  .card-body :global(figcaption) {
    font-size: 0.72rem;
    color: var(--text-soft);
    margin-top: 0.3em;
    font-style: italic;
  }

  .card-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.75rem;
    padding-top: 0.6rem;
    border-top: 1px dashed var(--border-soft);
  }

  .tag {
    font-size: 0.68rem;
    color: var(--text-soft);
    font-family: var(--font-mono);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .tag:hover {
    color: var(--flame);
  }
</style>
