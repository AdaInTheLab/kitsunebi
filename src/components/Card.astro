---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  card: CollectionEntry<'cards'>;
  index?: number;
  /** Number of comments on this card. Surfaced as a small chip in the footer when > 0. */
  commentCount?: number;
}

const { card, index = 0, commentCount = 0 } = Astro.props;
const { Content } = await render(card);
const data = card.data;

const due = data.due ? new Date(data.due) : null;
const now = new Date();
const daysUntilDue = due ? Math.ceil((due.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)) : null;
const dueClass = daysUntilDue === null
  ? ''
  : daysUntilDue < 0
    ? 'overdue'
    : daysUntilDue <= 3
      ? 'urgent'
      : daysUntilDue <= 7
        ? 'soon'
        : '';
---

<article
  class={`card status-${data.status}`}
  style={`--card-index: ${index};`}
  data-owner={data.owner}
  data-collaborators={data.collaborators.join(',')}
  data-tags={data.tags.join(',')}
  data-card-id={data.id}
  data-status={data.status}
  data-order={typeof data.order === 'number' ? String(data.order) : ''}
  data-created={data.created ?? ''}
  draggable="true"
>
  <header class="card-head">
    <h3 class="card-title">
      <a href={`/cards/${data.id}/`} class="card-title-link">{data.title}</a>
      <button class="card-title-edit" type="button" aria-label="Edit title">✎</button>
    </h3>
    <div class="card-meta">
      <span class="card-owner-chip" data-owner={data.owner}>
        <span class="owner">🦊 {data.owner}</span>
        <button class="card-owner-edit" type="button" aria-label="Edit owner">✎</button>
      </span>
      {due && (
        <span class={`due ${dueClass}`} title={data.due ?? undefined}>
          {due.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
        </span>
      )}
    </div>
  </header>

  {data.collaborators.length > 0 && (
    <div class="collaborators">
      {data.collaborators.map((c) => <span class="chip">{c}</span>)}
    </div>
  )}

  <button
    class="card-body-toggle"
    type="button"
    aria-expanded="false"
    aria-controls={`body-${data.id}`}
    aria-label="Toggle card body"
    title="Click to expand"
  >
    <span class="chevron" aria-hidden="true">^</span>
  </button>

  <div id={`body-${data.id}`} class="card-body">
    <Content />
  </div>

  <footer class="card-foot">
    {data.tags.map((t) => (
      <span class="card-tag-chip" data-tag={t}>
        <a href={`/tags/${t}/`} class="tag">#{t}</a>
        <button class="card-tag-remove" type="button" aria-label={`Remove tag ${t}`}>✕</button>
      </span>
    ))}
    <button class="card-tag-add" type="button" aria-label="Add a tag">+ tag</button>
    {commentCount > 0 && (
      <a href={`/cards/${data.id}/#comments`} class="card-comments-count" aria-label={`${commentCount} comment${commentCount === 1 ? '' : 's'}`} title={`${commentCount} comment${commentCount === 1 ? '' : 's'}`}>
        💬 {commentCount}
      </a>
    )}
  </footer>
</article>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--flame);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    margin-bottom: 0.75rem;
    box-shadow: 0 1px 0 var(--flame-glow) inset, 0 0 18px -8px var(--flame-glow);
    transition: transform 120ms ease, box-shadow 180ms ease, background 160ms ease;
    animation: cardIgnite 600ms cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: calc(var(--card-index, 0) * 45ms);
  }

  @keyframes cardIgnite {
    0%   { opacity: 0; transform: translateY(6px); filter: blur(2px); }
    60%  { opacity: 0.9; filter: blur(0); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .card { animation: none; }
  }

  .card:hover,
  .card.kbd-focus {
    background: var(--bg-card-hover);
    transform: translateY(-1px);
    box-shadow: 0 2px 0 var(--flame-glow) inset, 0 0 22px -6px var(--flame-glow);
  }

  .card.kbd-focus {
    outline: 1px solid var(--flame);
    outline-offset: 1px;
  }

  /* Drag-and-drop affordances. Cards are draggable from anywhere; we use
     `cursor: grab` on hover so it's discoverable, and `grabbing` while held. */
  .card { cursor: grab; }
  .card:active { cursor: grabbing; }

  .card.is-dragging {
    opacity: 0.45;
    transform: scale(0.98) translateY(-1px);
  }

  /* Don't let inner links/buttons override the grab cursor — but DO let
     them remain clickable. The drag listener stops short of them. */
  .card a, .card button {
    cursor: pointer;
  }

  .status-backlog { --flame: var(--flame-backlog); --flame-glow: var(--flame-backlog-glow); }
  .status-in_progress { --flame: var(--flame-in_progress); --flame-glow: var(--flame-in_progress-glow); }
  .status-blocked { --flame: var(--flame-blocked); --flame-glow: var(--flame-blocked-glow); }
  .status-done { --flame: var(--flame-done); --flame-glow: var(--flame-done-glow); }
  .status-archived { --flame: var(--flame-archived); --flame-glow: var(--flame-archived-glow); opacity: 0.55; }

  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.005em;
    flex: 1;
  }

  .card-title a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .card-title a:hover {
    color: var(--flame);
    border-bottom-color: var(--flame);
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-end;
    font-size: 0.75rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .owner {
    color: var(--text-dim);
  }

  .due {
    color: var(--text-soft);
    font-variant-numeric: tabular-nums;
  }

  .due.soon { color: var(--flame-done); }

  .due.urgent {
    color: var(--flame-in_progress);
    font-weight: 600;
    text-shadow: 0 0 8px var(--flame-in_progress-glow);
    animation: urgentPulse 2.4s ease-in-out infinite;
  }

  .due.overdue {
    color: var(--flame-blocked);
    font-weight: 700;
    text-shadow: 0 0 10px var(--flame-blocked-glow);
    animation: overduePulse 1.6s ease-in-out infinite;
  }

  @keyframes urgentPulse {
    0%, 100% { opacity: 0.85; text-shadow: 0 0 8px var(--flame-in_progress-glow); }
    50%      { opacity: 1;    text-shadow: 0 0 14px var(--flame-in_progress); }
  }

  @keyframes overduePulse {
    0%, 100% { opacity: 0.85; text-shadow: 0 0 10px var(--flame-blocked-glow); }
    50%      { opacity: 1;    text-shadow: 0 0 18px var(--flame-blocked); }
  }

  @media (prefers-reduced-motion: reduce) {
    .due.urgent, .due.overdue { animation: none; }
  }

  .collaborators {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.6rem;
  }

  .chip {
    background: var(--bg-0);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.08rem 0.55rem;
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  /* Body is hidden by default — most cards have a lot of body text and
     it overwhelms the board. The `^` toggle below the header expands
     it on demand. State persists per-card in localStorage. */
  .card-body {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.55;
    display: none;
  }

  .card.is-expanded .card-body {
    display: block;
  }

  .card-body-toggle {
    display: block;
    width: 100%;
    padding: 0.2rem 0;
    background: transparent;
    border: none;
    color: var(--text-soft);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1;
    cursor: pointer;
    text-align: center;
    transition: color 150ms ease, background 150ms ease;
  }

  .card-body-toggle:hover,
  .card-body-toggle:focus-visible {
    color: var(--flame);
    outline: none;
  }

  .card-body-toggle .chevron {
    display: inline-block;
    font-weight: 700;
    transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .card.is-expanded .card-body-toggle .chevron {
    transform: rotate(180deg);
  }

  /* When expanded, soften the toggle so it reads as a "collapse handle"
     rather than competing with the body. */
  .card.is-expanded .card-body-toggle {
    margin-bottom: 0.4rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px dashed var(--border-soft);
  }

  .card-body :global(p) {
    margin: 0 0 0.6em 0;
  }

  .card-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .card-body :global(ul) {
    padding-left: 1.1em;
    margin: 0.4em 0;
  }

  .card-body :global(li) {
    margin-bottom: 0.15em;
  }

  .card-body :global(input[type="checkbox"]) {
    accent-color: var(--flame);
    margin-right: 0.35em;
  }

  .card-body :global(h1),
  .card-body :global(h2),
  .card-body :global(h3),
  .card-body :global(h4) {
    font-size: 0.85rem;
    margin: 0.9em 0 0.3em 0;
    color: var(--text);
    font-weight: 600;
  }

  .card-body :global(strong) {
    color: var(--text);
  }

  /* On the board, attached images render as 50×50 1:1 thumbnails instead of
     full-width. Multiple thumbs flow inline-block and wrap. The full image
     is still viewable on the card detail page. */
  .card-body :global(.thumb) {
    position: relative;
    display: inline-block;
    margin: 0.4em 0.3em 0.4em 0;
    vertical-align: top;
  }

  .card-body :global(.thumb img),
  .card-body :global(.thumb video) {
    display: block;
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border-soft);
    transition: border-color 180ms ease, box-shadow 220ms ease;
  }

  .card:hover .card-body :global(.thumb img),
  .card:hover .card-body :global(.thumb video) {
    border-color: var(--flame);
    box-shadow: 0 0 14px -4px var(--flame-glow);
  }

  .card-body :global(.thumb-remove) {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 16px;
    height: 16px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.72);
    color: #fff;
    font-size: 11px;
    line-height: 14px;
    text-align: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 150ms ease, background 150ms ease;
  }

  .card-body :global(.thumb:hover .thumb-remove),
  .card-body :global(.thumb-remove:focus-visible) {
    opacity: 1;
  }

  .card-body :global(.thumb-remove:hover),
  .card-body :global(.thumb-remove:focus-visible) {
    background: var(--flame-blocked);
  }

  .card-body :global(figure) {
    margin: 0.6em 0;
  }

  .card-body :global(figcaption) {
    font-size: 0.72rem;
    color: var(--text-soft);
    margin-top: 0.3em;
    font-style: italic;
  }

  .card-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.75rem;
    padding-top: 0.6rem;
    border-top: 1px dashed var(--border-soft);
  }

  .tag {
    font-size: 0.68rem;
    color: var(--text-soft);
    font-family: var(--font-mono);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .tag:hover {
    color: var(--flame);
  }

  /* ---------- Inline-edit chips on board cards ---------- */
  /* Same shape as detail-page chips: hover reveals an edit/remove affordance,
     click swaps for an input. Distinct class names so layout/sizing stays
     small enough for the board context. */

  .card-title {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .card-title-link {
    flex: 1;
    min-width: 0;
  }

  .card-title-edit,
  .card-owner-edit,
  .card-tag-remove {
    width: 14px;
    height: 14px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--text-soft);
    font-size: 0.62rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0;
    transition: opacity 120ms ease, color 120ms ease, background 120ms ease;
  }

  .card:hover .card-title-edit,
  .card:hover .card-owner-edit,
  .card-title-edit:focus-visible,
  .card-owner-edit:focus-visible {
    opacity: 1;
  }

  .card-title-edit:hover,
  .card-title-edit:focus-visible,
  .card-owner-edit:hover,
  .card-owner-edit:focus-visible {
    color: var(--flame);
    background: var(--flame-glow);
    outline: none;
  }

  .card-title.is-editing .card-title-link,
  .card-title.is-editing .card-title-edit {
    display: none;
  }

  .card-title-input {
    flex: 1;
    background: var(--bg-0);
    border: 1px solid var(--flame);
    border-radius: 4px;
    padding: 0.05rem 0.4rem;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    outline: none;
    box-shadow: 0 0 14px -6px var(--flame-glow);
  }

  .card-owner-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    transition: opacity 150ms ease;
  }

  .card-owner-chip.saving,
  .card-title.saving {
    opacity: 0.45;
    pointer-events: none;
  }

  .card-owner-chip.is-editing .owner,
  .card-owner-chip.is-editing .card-owner-edit {
    display: none;
  }

  .card-owner-input {
    background: var(--bg-0);
    border: 1px solid var(--flame);
    border-radius: 999px;
    padding: 0.02rem 0.45rem;
    font: inherit;
    font-size: 0.74rem;
    color: var(--text);
    outline: none;
    width: 6rem;
    box-shadow: 0 0 12px -6px var(--flame-glow);
  }

  .card-tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.05rem;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0 0.05rem 0 0.2rem;
    transition: border-color 150ms ease, background 150ms ease, opacity 150ms ease;
  }

  .card:hover .card-tag-chip:hover {
    border-color: var(--border);
    background: var(--bg-0);
  }

  .card-tag-chip.saving {
    opacity: 0.45;
    pointer-events: none;
  }

  .card:hover .card-tag-chip:hover .card-tag-remove,
  .card-tag-remove:focus-visible {
    opacity: 1;
  }

  .card-tag-remove:hover,
  .card-tag-remove:focus-visible {
    color: #fff;
    background: var(--flame-blocked);
    outline: none;
  }

  .card-tag-add {
    background: transparent;
    border: 1px dashed var(--border);
    border-radius: 999px;
    padding: 0 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--text-soft);
    cursor: pointer;
    opacity: 0;
    transition: opacity 120ms ease, border-color 150ms ease, color 150ms ease, background 150ms ease;
  }

  .card:hover .card-tag-add,
  .card-tag-add:focus-visible {
    opacity: 1;
  }

  .card-tag-add:hover,
  .card-tag-add:focus-visible {
    border-color: var(--flame);
    color: var(--flame);
    background: var(--flame-glow);
    outline: none;
  }

  /* Comment-count badge: subtle when the card has any thread, anchored to
     the right side of the footer so it sits opposite the tags. */
  .card-comments-count {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--text-soft);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0 0.45rem;
    line-height: 1.5;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  .card-comments-count:hover,
  .card-comments-count:focus-visible {
    color: var(--flame);
    border-color: var(--flame);
    background: var(--flame-glow);
    outline: none;
  }

  .card-tag-input {
    background: var(--bg-0);
    border: 1px solid var(--flame);
    border-radius: 999px;
    padding: 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--text);
    outline: none;
    width: 7rem;
    box-shadow: 0 0 12px -6px var(--flame-glow);
  }

  /* When a card has zero tags, the footer shrinks to just the +tag button.
     Hide the dashed border so the empty footer doesn't draw attention. */
  .card-foot:has(.card-tag-chip) {
    /* keep the dashed border-top defined above */
  }

  .card-foot:not(:has(.card-tag-chip)) {
    border-top: none;
    margin-top: 0.4rem;
    padding-top: 0;
  }
</style>

<script>
  // Inline-edit chips on board cards (also active on /archive since both
  // pages render via Card.astro). Mirrors the detail-page behavior at a
  // smaller scale: hover reveals an affordance, click swaps for an input,
  // Enter/blur saves, Escape cancels. PATCHes /api/cards/:id with the
  // changed field; on success the DOM is patched in place — no page
  // reload, so drag-drop and filter state survive the edit.

  const CHIP_SELECTORS = [
    '.card-title-edit',
    '.card-owner-edit',
    '.card-body-toggle',
    '.card-tag-remove',
    '.card-tag-add',
    '.card-title-input',
    '.card-owner-input',
    '.card-tag-input',
  ].join(', ');

  // Cards have draggable=true, so a mousedown anywhere inside would normally
  // start a drag. Block that for chip controls (mirrors the thumbnail-remove
  // pattern). Capture-phase so we beat the document-level dragstart handler
  // in index.astro.
  document.addEventListener(
    'mousedown',
    (e) => {
      if ((e.target as HTMLElement).closest(CHIP_SELECTORS)) e.stopPropagation();
    },
    true,
  );
  document.addEventListener(
    'dragstart',
    (e) => {
      if ((e.target as HTMLElement).closest(CHIP_SELECTORS)) e.preventDefault();
    },
    true,
  );

  async function patchCard(cardId: string, body: Record<string, unknown>): Promise<boolean> {
    try {
      const r = await fetch(`/api/cards/${encodeURIComponent(cardId)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!r.ok) {
        const errBody = await r.text();
        throw new Error(`HTTP ${r.status}: ${errBody.slice(0, 200)}`);
      }
      return true;
    } catch (err) {
      console.error('card patch failed:', err);
      alert(`Couldn't save: ${err instanceof Error ? err.message : 'unknown error'}`);
      return false;
    }
  }

  // ---------- Title ----------
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.card-title-edit');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const titleEl = btn.closest<HTMLElement>('.card-title');
    const link = titleEl?.querySelector<HTMLAnchorElement>('.card-title-link');
    const card = btn.closest<HTMLElement>('.card');
    if (!titleEl || !link || !card) return;
    const cardId = card.dataset.cardId ?? '';
    const current = link.textContent?.trim() ?? '';

    titleEl.classList.add('is-editing');
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'card-title-input';
    input.value = current;
    input.maxLength = 200;
    titleEl.appendChild(input);
    input.focus();
    input.select();

    let dispatched = false;
    const finish = async (cancelled: boolean) => {
      if (dispatched) return;
      dispatched = true;
      const next = input.value.trim().replace(/\s+/g, ' ');
      input.remove();
      titleEl.classList.remove('is-editing');
      if (cancelled || !next || next === current) return;

      titleEl.classList.add('saving');
      const ok = await patchCard(cardId, { title: next });
      if (ok) link.textContent = next;
      titleEl.classList.remove('saving');
    };
    input.addEventListener('keydown', (ke) => {
      if (ke.key === 'Enter') { ke.preventDefault(); finish(false); }
      else if (ke.key === 'Escape') { ke.preventDefault(); finish(true); }
    });
    input.addEventListener('blur', () => finish(false));
  });

  // ---------- Owner ----------
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.card-owner-edit');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const chip = btn.closest<HTMLElement>('.card-owner-chip');
    const ownerSpan = chip?.querySelector<HTMLElement>('.owner');
    const card = btn.closest<HTMLElement>('.card');
    if (!chip || !ownerSpan || !card) return;
    const cardId = card.dataset.cardId ?? '';
    const current = chip.dataset.owner ?? '';

    chip.classList.add('is-editing');
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'card-owner-input';
    input.value = current;
    input.maxLength = 60;
    chip.appendChild(input);
    input.focus();
    input.select();

    let dispatched = false;
    const finish = async (cancelled: boolean) => {
      if (dispatched) return;
      dispatched = true;
      const next = input.value.trim();
      input.remove();
      chip.classList.remove('is-editing');
      if (cancelled || !next || next === current) return;

      chip.classList.add('saving');
      const ok = await patchCard(cardId, { owner: next });
      if (ok) {
        ownerSpan.textContent = `🦊 ${next}`;
        chip.dataset.owner = next;
        card.dataset.owner = next;
      }
      chip.classList.remove('saving');
    };
    input.addEventListener('keydown', (ke) => {
      if (ke.key === 'Enter') { ke.preventDefault(); finish(false); }
      else if (ke.key === 'Escape') { ke.preventDefault(); finish(true); }
    });
    input.addEventListener('blur', () => finish(false));
  });

  // ---------- Tag remove ----------
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.card-tag-remove');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const chip = btn.closest<HTMLElement>('.card-tag-chip');
    const card = btn.closest<HTMLElement>('.card');
    const tag = chip?.dataset.tag;
    if (!chip || !card || !tag) return;
    const cardId = card.dataset.cardId ?? '';

    const tags = (card.dataset.tags ?? '').split(',').filter(Boolean);
    const next = tags.filter((t) => t !== tag);

    chip.classList.add('saving');
    const ok = await patchCard(cardId, { tags: next });
    if (ok) {
      chip.remove();
      card.dataset.tags = next.join(',');
    } else {
      chip.classList.remove('saving');
    }
  });

  // ---------- Tag add ----------
  function makeBoardTagChip(tag: string): HTMLElement {
    const span = document.createElement('span');
    span.className = 'card-tag-chip';
    span.dataset.tag = tag;

    const a = document.createElement('a');
    a.href = `/tags/${encodeURIComponent(tag)}/`;
    a.className = 'tag';
    a.textContent = `#${tag}`;
    span.appendChild(a);

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'card-tag-remove';
    removeBtn.setAttribute('aria-label', `Remove tag ${tag}`);
    removeBtn.textContent = '✕';
    span.appendChild(removeBtn);

    return span;
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.card-tag-add');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const foot = btn.closest<HTMLElement>('.card-foot');
    const card = btn.closest<HTMLElement>('.card');
    if (!foot || !card) return;
    if (foot.querySelector('.card-tag-input')) return;
    const cardId = card.dataset.cardId ?? '';

    btn.style.display = 'none';
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'card-tag-input';
    input.placeholder = 'tag-name';
    input.maxLength = 60;
    foot.insertBefore(input, btn);
    input.focus();

    let dispatched = false;
    const finish = async (cancelled: boolean) => {
      if (dispatched) return;
      dispatched = true;
      const next = input.value.trim();
      input.remove();
      btn.style.display = '';
      if (cancelled || !next) return;

      const tags = (card.dataset.tags ?? '').split(',').filter(Boolean);
      if (tags.includes(next)) return;
      const updated = [...tags, next];

      const ok = await patchCard(cardId, { tags: updated });
      if (ok) {
        foot.insertBefore(makeBoardTagChip(next), btn);
        card.dataset.tags = updated.join(',');
      }
    };
    input.addEventListener('keydown', (ke) => {
      if (ke.key === 'Enter') { ke.preventDefault(); finish(false); }
      else if (ke.key === 'Escape') { ke.preventDefault(); finish(true); }
    });
    input.addEventListener('blur', () => finish(false));
  });

  // ---------- Body collapse/expand ----------
  // Bodies are hidden by default; the `^` toggle expands them. Per-card
  // state persists at localStorage[kitsunebi:expanded-cards] so once
  // you open something it stays open across reloads + drag-drops +
  // page navigations back to the board.
  const EXPANDED_KEY = 'kitsunebi:expanded-cards';

  function readExpandedSet(): Set<string> {
    try {
      const raw = localStorage.getItem(EXPANDED_KEY);
      if (!raw) return new Set();
      const parsed = JSON.parse(raw);
      return new Set(Array.isArray(parsed) ? parsed : []);
    } catch {
      return new Set();
    }
  }

  function saveExpandedSet(set: Set<string>) {
    try {
      localStorage.setItem(EXPANDED_KEY, JSON.stringify([...set]));
    } catch {
      // Quota / private mode — non-fatal.
    }
  }

  // Apply persisted expanded state on load.
  (() => {
    const expanded = readExpandedSet();
    if (expanded.size === 0) return;
    document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
      const id = card.dataset.cardId;
      if (id && expanded.has(id)) {
        card.classList.add('is-expanded');
        const btn = card.querySelector<HTMLButtonElement>('.card-body-toggle');
        if (btn) btn.setAttribute('aria-expanded', 'true');
      }
    });
  })();

  // Toggle handler.
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.card-body-toggle');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const card = btn.closest<HTMLElement>('.card');
    if (!card) return;
    const id = card.dataset.cardId;
    if (!id) return;

    const nowExpanded = !card.classList.contains('is-expanded');
    card.classList.toggle('is-expanded', nowExpanded);
    btn.setAttribute('aria-expanded', nowExpanded ? 'true' : 'false');

    const set = readExpandedSet();
    if (nowExpanded) set.add(id);
    else set.delete(id);
    saveExpandedSet(set);
  });
</script>
